{
  "id": 114,
  "name": "An-Nas",
  "transliteratedName": "An-Nās",
  "arabicName": "الناس",
  "translatedName": "Mankind",
  "versesCount": 6,
  "ayahs": [
    {
      "number": 1,
      "verseKey": "114:1",
      "arabic": " قُلْ أَعُوذُ بِرَبِّ ٱلنَّاسِ",
      "transliteration": "Qul aAAoothu birabbi annas",
      "translation": "Say, \"I seek refuge in the Lord of mankind,"
    },
    {
      "number": 2,
      "verseKey": "114:2",
      "arabic": "مَلِكِ ٱلنَّاسِ",
      "transliteration": "Maliki annas",
      "translation": "The Sovereign of mankind,"
    },
    {
      "number": 3,
      "verseKey": "114:3",
      "arabic": "إِلَـٰهِ ٱلنَّاسِ",
      "transliteration": "Ilahi annas",
      "translation": "The God of mankind,"
    },
    {
      "number": 4,
      "verseKey": "114:4",
      "arabic": "مِن شَرِّ ٱلْوَسْوَاسِ ٱلْخَنَّاسِ",
      "transliteration": "Min sharri alwaswasi alkhannas",
      "translation": "From the evil of the retreating whisperer[2016] -"
    },
    {
      "number": 5,
      "verseKey": "114:5",
      "arabic": "ٱلَّذِى يُوَسْوِسُ فِى صُدُورِ ٱلنَّاسِ",
      "transliteration": "Allathee yuwaswisu fee sudoori annas",
      "translation": "Who whispers [evil] into the breasts of mankind -"
    },
    {
      "number": 6,
      "verseKey": "114:6",
      "arabic": "مِنَ ٱلْجِنَّةِ وَٱلنَّاسِ",
      "transliteration": "Mina aljinnati wannas",
      "translation": "From among the jinn and mankind.\"[2017]"
    }
  ]
}