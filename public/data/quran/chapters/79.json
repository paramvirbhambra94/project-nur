{
  "id": 79,
  "name": "An-Nazi'at",
  "transliteratedName": "An-Nāzi`āt",
  "arabicName": "النازعات",
  "translatedName": "Those who drag forth",
  "versesCount": 46,
  "ayahs": [
    {
      "number": 1,
      "verseKey": "79:1",
      "arabic": " وَٱلنَّـٰزِعَـٰتِ غَرْقًا",
      "simpleArabic": "وَالنَّازِعَاتِ غَرْقًا",
      "transliteration": "WannaziAAati gharqa",
      "translation": "By those [angels] who extract with violence[1833]"
    },
    {
      "number": 2,
      "verseKey": "79:2",
      "arabic": "وَٱلنَّـٰشِطَـٰتِ نَشْطًا",
      "simpleArabic": "وَالنَّاشِطَاتِ نَشْطًا",
      "transliteration": "Wannashitati nashta",
      "translation": "And [by] those who remove with ease[1834]"
    },
    {
      "number": 3,
      "verseKey": "79:3",
      "arabic": "وَٱلسَّـٰبِحَـٰتِ سَبْحًا",
      "simpleArabic": "وَالسَّابِحَاتِ سَبْحًا",
      "transliteration": "Wassabihati sabha",
      "translation": "And [by] those who glide [as if] swimming[1835]"
    },
    {
      "number": 4,
      "verseKey": "79:4",
      "arabic": "فَٱلسَّـٰبِقَـٰتِ سَبْقًا",
      "simpleArabic": "فَالسَّابِقَاتِ سَبْقًا",
      "transliteration": "Fassabiqati sabqa",
      "translation": "And those who race each other in a race[1836]"
    },
    {
      "number": 5,
      "verseKey": "79:5",
      "arabic": "فَٱلْمُدَبِّرَٰتِ أَمْرًا",
      "simpleArabic": "فَالْمُدَبِّرَاتِ أَمْرًا",
      "transliteration": "Falmudabbirati amra",
      "translation": "And those who arrange [each] matter,[1837]"
    },
    {
      "number": 6,
      "verseKey": "79:6",
      "arabic": "يَوْمَ تَرْجُفُ ٱلرَّاجِفَةُ",
      "simpleArabic": "يَوْمَ تَرْجُفُ الرَّاجِفَةُ",
      "transliteration": "Yawma tarjufu arrajifa",
      "translation": "On the Day the blast [of the Horn] will convulse [creation],"
    },
    {
      "number": 7,
      "verseKey": "79:7",
      "arabic": "تَتْبَعُهَا ٱلرَّادِفَةُ",
      "simpleArabic": "تَتْبَعُهَا الرَّادِفَةُ",
      "transliteration": "TatbaAAuha arradifa",
      "translation": "There will follow it the subsequent [one]."
    },
    {
      "number": 8,
      "verseKey": "79:8",
      "arabic": "قُلُوبٌ يَوْمَئِذٍ وَاجِفَةٌ",
      "simpleArabic": "قُلُوبٌ يَوْمَئِذٍ وَاجِفَةٌ",
      "transliteration": "Quloobun yawma-ithin wajifa",
      "translation": "Hearts,[1838] that Day, will tremble,"
    },
    {
      "number": 9,
      "verseKey": "79:9",
      "arabic": "أَبْصَـٰرُهَا خَـٰشِعَةٌ",
      "simpleArabic": "أَبْصَارُهَا خَاشِعَةٌ",
      "transliteration": "Absaruha khashiAAa",
      "translation": "Their eyes[1839] humbled."
    },
    {
      "number": 10,
      "verseKey": "79:10",
      "arabic": "يَقُولُونَ أَءِنَّا لَمَرْدُودُونَ فِى ٱلْحَافِرَةِ",
      "simpleArabic": "يَقُولُونَ أَإِنَّا لَمَرْدُودُونَ فِي الْحَافِرَةِ",
      "transliteration": "Yaqooloona a-inna lamardoodoona feealhafira",
      "translation": "They are [presently] saying, \"Will we indeed be returned to [our] former state [of life]?"
    },
    {
      "number": 11,
      "verseKey": "79:11",
      "arabic": "أَءِذَا كُنَّا عِظَـٰمًا نَّخِرَةً",
      "simpleArabic": "أَإِذَا كُنَّا عِظَامًا نَّخِرَةً",
      "transliteration": "A-itha kunna AAithamannakhira",
      "translation": "Even if we should be decayed bones?\"[1840]"
    },
    {
      "number": 12,
      "verseKey": "79:12",
      "arabic": "قَالُوا۟ تِلْكَ إِذًا كَرَّةٌ خَاسِرَةٌ",
      "simpleArabic": "قَالُوا تِلْكَ إِذًا كَرَّةٌ خَاسِرَةٌ",
      "transliteration": "Qaloo tilka ithan karratun khasira",
      "translation": "They say, \"That, then, would be a losing return.\"[1841]"
    },
    {
      "number": 13,
      "verseKey": "79:13",
      "arabic": "فَإِنَّمَا هِىَ زَجْرَةٌ وَٰحِدَةٌ",
      "simpleArabic": "فَإِنَّمَا هِيَ زَجْرَةٌ وَاحِدَةٌ",
      "transliteration": "Fa-innama hiya zajratun wahida",
      "translation": "Indeed, it will be but one shout,"
    },
    {
      "number": 14,
      "verseKey": "79:14",
      "arabic": "فَإِذَا هُم بِٱلسَّاهِرَةِ",
      "simpleArabic": "فَإِذَا هُم بِالسَّاهِرَةِ",
      "transliteration": "Fa-itha hum bissahira",
      "translation": "And suddenly they will be [alert] upon the earth's surface."
    },
    {
      "number": 15,
      "verseKey": "79:15",
      "arabic": "هَلْ أَتَىٰكَ حَدِيثُ مُوسَىٰٓ",
      "simpleArabic": "هَلْ أَتَاكَ حَدِيثُ مُوسَىٰ",
      "transliteration": "Hal ataka hadeethu moosa",
      "translation": "Has there reached you the story of Moses? -"
    },
    {
      "number": 16,
      "verseKey": "79:16",
      "arabic": "إِذْ نَادَىٰهُ رَبُّهُۥ بِٱلْوَادِ ٱلْمُقَدَّسِ طُوًى",
      "simpleArabic": "إِذْ نَادَاهُ رَبُّهُ بِالْوَادِ الْمُقَدَّسِ طُوًى",
      "transliteration": "Ith nadahu rabbuhu bilwadialmuqaddasi tuwa",
      "translation": "When his Lord called to him in the sacred valley of Ṭuwā,"
    },
    {
      "number": 17,
      "verseKey": "79:17",
      "arabic": "ٱذْهَبْ إِلَىٰ فِرْعَوْنَ إِنَّهُۥ طَغَىٰ",
      "simpleArabic": "اذْهَبْ إِلَىٰ فِرْعَوْنَ إِنَّهُ طَغَىٰ",
      "transliteration": "Ithhab ila firAAawna innahu tagha",
      "translation": "\"Go to Pharaoh. Indeed, he has transgressed."
    },
    {
      "number": 18,
      "verseKey": "79:18",
      "arabic": "فَقُلْ هَل لَّكَ إِلَىٰٓ أَن تَزَكَّىٰ",
      "simpleArabic": "فَقُلْ هَل لَّكَ إِلَىٰ أَن تَزَكَّىٰ",
      "transliteration": "Faqul hal laka ila an tazakka",
      "translation": "And say to him, 'Would you [be willing to] purify yourself"
    },
    {
      "number": 19,
      "verseKey": "79:19",
      "arabic": "وَأَهْدِيَكَ إِلَىٰ رَبِّكَ فَتَخْشَىٰ",
      "simpleArabic": "وَأَهْدِيَكَ إِلَىٰ رَبِّكَ فَتَخْشَىٰ",
      "transliteration": "Waahdiyaka ila rabbika fatakhsha",
      "translation": "And let me guide you to your Lord so you would fear [Him]?'\""
    },
    {
      "number": 20,
      "verseKey": "79:20",
      "arabic": "فَأَرَىٰهُ ٱلْـَٔايَةَ ٱلْكُبْرَىٰ",
      "simpleArabic": "فَأَرَاهُ الْآيَةَ الْكُبْرَىٰ",
      "transliteration": "Faarahu al-ayata alkubra",
      "translation": "And he showed him the greatest sign,[1842]"
    },
    {
      "number": 21,
      "verseKey": "79:21",
      "arabic": "فَكَذَّبَ وَعَصَىٰ",
      "simpleArabic": "فَكَذَّبَ وَعَصَىٰ",
      "transliteration": "Fakaththaba waAAasa",
      "translation": "But he [i.e., Pharaoh] denied and disobeyed."
    },
    {
      "number": 22,
      "verseKey": "79:22",
      "arabic": "ثُمَّ أَدْبَرَ يَسْعَىٰ",
      "simpleArabic": "ثُمَّ أَدْبَرَ يَسْعَىٰ",
      "transliteration": "Thumma adbara yasAAa",
      "translation": "Then he turned his back, striving [i.e., plotting].[1843]"
    },
    {
      "number": 23,
      "verseKey": "79:23",
      "arabic": "فَحَشَرَ فَنَادَىٰ",
      "simpleArabic": "فَحَشَرَ فَنَادَىٰ",
      "transliteration": "Fahashara fanada",
      "translation": "And he gathered [his people] and called out"
    },
    {
      "number": 24,
      "verseKey": "79:24",
      "arabic": "فَقَالَ أَنَا۠ رَبُّكُمُ ٱلْأَعْلَىٰ",
      "simpleArabic": "فَقَالَ أَنَا رَبُّكُمُ الْأَعْلَىٰ",
      "transliteration": "Faqala ana rabbukumu al-aAAla",
      "translation": "And said, \"I am your most exalted lord.\""
    },
    {
      "number": 25,
      "verseKey": "79:25",
      "arabic": "فَأَخَذَهُ ٱللَّهُ نَكَالَ ٱلْـَٔاخِرَةِ وَٱلْأُولَىٰٓ",
      "simpleArabic": "فَأَخَذَهُ اللَّهُ نَكَالَ الْآخِرَةِ وَالْأُولَىٰ",
      "transliteration": "Faakhathahu Allahu nakalaal-akhirati wal-oola",
      "translation": "So Allāh seized him in exemplary punishment for the last and the first [transgression].[1844]."
    },
    {
      "number": 26,
      "verseKey": "79:26",
      "arabic": "إِنَّ فِى ذَٰلِكَ لَعِبْرَةً لِّمَن يَخْشَىٰٓ",
      "simpleArabic": "إِنَّ فِي ذَٰلِكَ لَعِبْرَةً لِّمَن يَخْشَىٰ",
      "transliteration": "Inna fee thalika laAAibratan limanyakhsha",
      "translation": "Indeed in that is a lesson [i.e., warning] for whoever would fear [Allāh]."
    },
    {
      "number": 27,
      "verseKey": "79:27",
      "arabic": "ءَأَنتُمْ أَشَدُّ خَلْقًا أَمِ ٱلسَّمَآءُ ۚ بَنَىٰهَا",
      "simpleArabic": "أَأَنتُمْ أَشَدُّ خَلْقًا أَمِ السَّمَاءُ ۚ بَنَاهَا",
      "transliteration": "Aantum ashaddu khalqan ami assamaobanaha",
      "translation": "Are you a more difficult creation or is the heaven? He [i.e., Allāh] constructed it."
    },
    {
      "number": 28,
      "verseKey": "79:28",
      "arabic": "رَفَعَ سَمْكَهَا فَسَوَّىٰهَا",
      "simpleArabic": "رَفَعَ سَمْكَهَا فَسَوَّاهَا",
      "transliteration": "RafaAAa samkaha fasawwaha",
      "translation": "He raised its ceiling and proportioned it."
    },
    {
      "number": 29,
      "verseKey": "79:29",
      "arabic": "وَأَغْطَشَ لَيْلَهَا وَأَخْرَجَ ضُحَىٰهَا",
      "simpleArabic": "وَأَغْطَشَ لَيْلَهَا وَأَخْرَجَ ضُحَاهَا",
      "transliteration": "Waaghtasha laylaha waakhraja duhaha",
      "translation": "And He darkened its night and extracted its brightness.[1845]"
    },
    {
      "number": 30,
      "verseKey": "79:30",
      "arabic": "وَٱلْأَرْضَ بَعْدَ ذَٰلِكَ دَحَىٰهَآ",
      "simpleArabic": "وَالْأَرْضَ بَعْدَ ذَٰلِكَ دَحَاهَا",
      "transliteration": "Wal-arda baAAda thalikadahaha",
      "translation": "And after that He spread the earth."
    },
    {
      "number": 31,
      "verseKey": "79:31",
      "arabic": "أَخْرَجَ مِنْهَا مَآءَهَا وَمَرْعَىٰهَا",
      "simpleArabic": "أَخْرَجَ مِنْهَا مَاءَهَا وَمَرْعَاهَا",
      "transliteration": "Akhraja minha maahawamarAAaha",
      "translation": "He extracted from it its water and its pasture,"
    },
    {
      "number": 32,
      "verseKey": "79:32",
      "arabic": "وَٱلْجِبَالَ أَرْسَىٰهَا",
      "simpleArabic": "وَالْجِبَالَ أَرْسَاهَا",
      "transliteration": "Waljibala arsaha",
      "translation": "And the mountains He set firmly"
    },
    {
      "number": 33,
      "verseKey": "79:33",
      "arabic": "مَتَـٰعًا لَّكُمْ وَلِأَنْعَـٰمِكُمْ",
      "simpleArabic": "مَتَاعًا لَّكُمْ وَلِأَنْعَامِكُمْ",
      "transliteration": "MataAAan lakum wali-anAAamikum",
      "translation": "As enjoyment [i.e., provision] for you and your grazing livestock."
    },
    {
      "number": 34,
      "verseKey": "79:34",
      "arabic": "فَإِذَا جَآءَتِ ٱلطَّآمَّةُ ٱلْكُبْرَىٰ",
      "simpleArabic": "فَإِذَا جَاءَتِ الطَّامَّةُ الْكُبْرَىٰ",
      "transliteration": "Fa-itha jaati attammatualkubra",
      "translation": "But when there comes the greatest Overwhelming Calamity[1846] -"
    },
    {
      "number": 35,
      "verseKey": "79:35",
      "arabic": "يَوْمَ يَتَذَكَّرُ ٱلْإِنسَـٰنُ مَا سَعَىٰ",
      "simpleArabic": "يَوْمَ يَتَذَكَّرُ الْإِنسَانُ مَا سَعَىٰ",
      "transliteration": "Yawma yatathakkaru al-insanu masaAAa",
      "translation": "The Day when man will remember that for which he strove,"
    },
    {
      "number": 36,
      "verseKey": "79:36",
      "arabic": "وَبُرِّزَتِ ٱلْجَحِيمُ لِمَن يَرَىٰ",
      "simpleArabic": "وَبُرِّزَتِ الْجَحِيمُ لِمَن يَرَىٰ",
      "transliteration": "Waburrizati aljaheemu liman yara",
      "translation": "And Hellfire will be exposed for [all] those who see -"
    },
    {
      "number": 37,
      "verseKey": "79:37",
      "arabic": "فَأَمَّا مَن طَغَىٰ",
      "simpleArabic": "فَأَمَّا مَن طَغَىٰ",
      "transliteration": "Faamma man tagha",
      "translation": "So as for he who transgressed"
    },
    {
      "number": 38,
      "verseKey": "79:38",
      "arabic": "وَءَاثَرَ ٱلْحَيَوٰةَ ٱلدُّنْيَا",
      "simpleArabic": "وَآثَرَ الْحَيَاةَ الدُّنْيَا",
      "transliteration": "Waathara alhayata addunya",
      "translation": "And preferred the life of the world,"
    },
    {
      "number": 39,
      "verseKey": "79:39",
      "arabic": "فَإِنَّ ٱلْجَحِيمَ هِىَ ٱلْمَأْوَىٰ",
      "simpleArabic": "فَإِنَّ الْجَحِيمَ هِيَ الْمَأْوَىٰ",
      "transliteration": "Fa-inna aljaheema hiya alma/wa",
      "translation": "Then indeed, Hellfire will be [his] refuge."
    },
    {
      "number": 40,
      "verseKey": "79:40",
      "arabic": "وَأَمَّا مَنْ خَافَ مَقَامَ رَبِّهِۦ وَنَهَى ٱلنَّفْسَ عَنِ ٱلْهَوَىٰ",
      "simpleArabic": "وَأَمَّا مَنْ خَافَ مَقَامَ رَبِّهِ وَنَهَى النَّفْسَ عَنِ الْهَوَىٰ",
      "transliteration": "Waama man khafa maqamarabbihi wanaha annafsa AAani alhawa",
      "translation": "But as for he who feared the position of his Lord[1847] and prevented the soul from [unlawful] inclination,"
    },
    {
      "number": 41,
      "verseKey": "79:41",
      "arabic": "فَإِنَّ ٱلْجَنَّةَ هِىَ ٱلْمَأْوَىٰ",
      "simpleArabic": "فَإِنَّ الْجَنَّةَ هِيَ الْمَأْوَىٰ",
      "transliteration": "Fa-inna aljannata hiya alma/wa",
      "translation": "Then indeed, Paradise will be [his] refuge."
    },
    {
      "number": 42,
      "verseKey": "79:42",
      "arabic": "يَسْـَٔلُونَكَ عَنِ ٱلسَّاعَةِ أَيَّانَ مُرْسَىٰهَا",
      "simpleArabic": "يَسْأَلُونَكَ عَنِ السَّاعَةِ أَيَّانَ مُرْسَاهَا",
      "transliteration": "Yas-aloonaka AAani assaAAatiayyana mursaha",
      "translation": "They ask you, [O Muḥammad], about the Hour: when is its arrival?[1848]"
    },
    {
      "number": 43,
      "verseKey": "79:43",
      "arabic": "فِيمَ أَنتَ مِن ذِكْرَىٰهَآ",
      "simpleArabic": "فِيمَ أَنتَ مِن ذِكْرَاهَا",
      "transliteration": "Feema anta min thikraha",
      "translation": "In what [position] are you that you should mention it?[1849]"
    },
    {
      "number": 44,
      "verseKey": "79:44",
      "arabic": "إِلَىٰ رَبِّكَ مُنتَهَىٰهَآ",
      "simpleArabic": "إِلَىٰ رَبِّكَ مُنتَهَاهَا",
      "transliteration": "Ila rabbika muntahaha",
      "translation": "To your Lord is its finality.[1850]"
    },
    {
      "number": 45,
      "verseKey": "79:45",
      "arabic": "إِنَّمَآ أَنتَ مُنذِرُ مَن يَخْشَىٰهَا",
      "simpleArabic": "إِنَّمَا أَنتَ مُنذِرُ مَن يَخْشَاهَا",
      "transliteration": "Innama anta munthiru manyakhshaha",
      "translation": "You are only a warner for those who fear it."
    },
    {
      "number": 46,
      "verseKey": "79:46",
      "arabic": "كَأَنَّهُمْ يَوْمَ يَرَوْنَهَا لَمْ يَلْبَثُوٓا۟ إِلَّا عَشِيَّةً أَوْ ضُحَىٰهَا",
      "simpleArabic": "كَأَنَّهُمْ يَوْمَ يَرَوْنَهَا لَمْ يَلْبَثُوا إِلَّا عَشِيَّةً أَوْ ضُحَاهَا",
      "transliteration": "Kaannahum yawma yarawnaha lamyalbathoo illa AAashiyyatan aw duhaha",
      "translation": "It will be, on the Day they see it,[1851] as though they had not remained [in the world] except for an afternoon or a morning thereof."
    }
  ]
}