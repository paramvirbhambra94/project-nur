{
  "id": 80,
  "name": "'Abasa",
  "transliteratedName": "`Abasa",
  "arabicName": "عبس",
  "translatedName": "He Frowned",
  "versesCount": 42,
  "ayahs": [
    {
      "number": 1,
      "verseKey": "80:1",
      "arabic": " عَبَسَ وَتَوَلَّىٰٓ",
      "simpleArabic": "عَبَسَ وَتَوَلَّىٰ",
      "transliteration": "AAabasa watawalla",
      "translation": "He [i.e., the Prophet (ﷺ) ] frowned and turned away"
    },
    {
      "number": 2,
      "verseKey": "80:2",
      "arabic": "أَن جَآءَهُ ٱلْأَعْمَىٰ",
      "simpleArabic": "أَن جَاءَهُ الْأَعْمَىٰ",
      "transliteration": "An jaahu al-aAAma",
      "translation": "Because there came to him the blind man,[1853] [interrupting]."
    },
    {
      "number": 3,
      "verseKey": "80:3",
      "arabic": "وَمَا يُدْرِيكَ لَعَلَّهُۥ يَزَّكَّىٰٓ",
      "simpleArabic": "وَمَا يُدْرِيكَ لَعَلَّهُ يَزَّكَّىٰ",
      "transliteration": "Wama yudreeka laAAallahu yazzakka",
      "translation": "But what would make you perceive, [O Muḥammad], that perhaps he might be purified[1854]"
    },
    {
      "number": 4,
      "verseKey": "80:4",
      "arabic": "أَوْ يَذَّكَّرُ فَتَنفَعَهُ ٱلذِّكْرَىٰٓ",
      "simpleArabic": "أَوْ يَذَّكَّرُ فَتَنفَعَهُ الذِّكْرَىٰ",
      "transliteration": "Aw yaththakkaru fatanfaAAahu aththikra",
      "translation": "Or be reminded and the remembrance would benefit him?"
    },
    {
      "number": 5,
      "verseKey": "80:5",
      "arabic": "أَمَّا مَنِ ٱسْتَغْنَىٰ",
      "simpleArabic": "أَمَّا مَنِ اسْتَغْنَىٰ",
      "transliteration": "Amma mani istaghna",
      "translation": "As for he who thinks himself without need,[1855]"
    },
    {
      "number": 6,
      "verseKey": "80:6",
      "arabic": "فَأَنتَ لَهُۥ تَصَدَّىٰ",
      "simpleArabic": "فَأَنتَ لَهُ تَصَدَّىٰ",
      "transliteration": "Faanta lahu tasadda",
      "translation": "To him you give attention."
    },
    {
      "number": 7,
      "verseKey": "80:7",
      "arabic": "وَمَا عَلَيْكَ أَلَّا يَزَّكَّىٰ",
      "simpleArabic": "وَمَا عَلَيْكَ أَلَّا يَزَّكَّىٰ",
      "transliteration": "Wama AAalayka alla yazzakka",
      "translation": "And not upon you [is any blame] if he will not be purified.[1856]"
    },
    {
      "number": 8,
      "verseKey": "80:8",
      "arabic": "وَأَمَّا مَن جَآءَكَ يَسْعَىٰ",
      "simpleArabic": "وَأَمَّا مَن جَاءَكَ يَسْعَىٰ",
      "transliteration": "Waamma man jaaka yasAAa",
      "translation": "But as for he who came to you striving [for knowledge]"
    },
    {
      "number": 9,
      "verseKey": "80:9",
      "arabic": "وَهُوَ يَخْشَىٰ",
      "simpleArabic": "وَهُوَ يَخْشَىٰ",
      "transliteration": "Wahuwa yakhsha",
      "translation": "While he fears [Allāh],"
    },
    {
      "number": 10,
      "verseKey": "80:10",
      "arabic": "فَأَنتَ عَنْهُ تَلَهَّىٰ",
      "simpleArabic": "فَأَنتَ عَنْهُ تَلَهَّىٰ",
      "transliteration": "Faanta AAanhu talahha",
      "translation": "From him you are distracted."
    },
    {
      "number": 11,
      "verseKey": "80:11",
      "arabic": "كَلَّآ إِنَّهَا تَذْكِرَةٌ",
      "simpleArabic": "كَلَّا إِنَّهَا تَذْكِرَةٌ",
      "transliteration": "Kalla innaha tathkira",
      "translation": "No! Indeed, they [i.e., these verses] are a reminder;"
    },
    {
      "number": 12,
      "verseKey": "80:12",
      "arabic": "فَمَن شَآءَ ذَكَرَهُۥ",
      "simpleArabic": "فَمَن شَاءَ ذَكَرَهُ",
      "transliteration": "Faman shaa thakarah",
      "translation": "So whoever wills may remember it.[1857]"
    },
    {
      "number": 13,
      "verseKey": "80:13",
      "arabic": "فِى صُحُفٍ مُّكَرَّمَةٍ",
      "simpleArabic": "فِي صُحُفٍ مُّكَرَّمَةٍ",
      "transliteration": "Fee suhufin mukarrama",
      "translation": "[It is recorded] in honored sheets,"
    },
    {
      "number": 14,
      "verseKey": "80:14",
      "arabic": "مَّرْفُوعَةٍ مُّطَهَّرَةٍۭ",
      "simpleArabic": "مَّرْفُوعَةٍ مُّطَهَّرَةٍ",
      "transliteration": "MarfooAAatin mutahhara",
      "translation": "Exalted and purified,"
    },
    {
      "number": 15,
      "verseKey": "80:15",
      "arabic": "بِأَيْدِى سَفَرَةٍ",
      "simpleArabic": "بِأَيْدِي سَفَرَةٍ",
      "transliteration": "Bi-aydee safara",
      "translation": "[Carried] by the hands of messenger-angels,"
    },
    {
      "number": 16,
      "verseKey": "80:16",
      "arabic": "كِرَامٍۭ بَرَرَةٍ",
      "simpleArabic": "كِرَامٍ بَرَرَةٍ",
      "transliteration": "Kiramin barara",
      "translation": "Noble and dutiful."
    },
    {
      "number": 17,
      "verseKey": "80:17",
      "arabic": "قُتِلَ ٱلْإِنسَـٰنُ مَآ أَكْفَرَهُۥ",
      "simpleArabic": "قُتِلَ الْإِنسَانُ مَا أَكْفَرَهُ",
      "transliteration": "Qutila al-insanu ma akfarah",
      "translation": "Destroyed [i.e., cursed] is man;[1858] how disbelieving is he."
    },
    {
      "number": 18,
      "verseKey": "80:18",
      "arabic": "مِنْ أَىِّ شَىْءٍ خَلَقَهُۥ",
      "simpleArabic": "مِنْ أَيِّ شَيْءٍ خَلَقَهُ",
      "transliteration": "Min ayyi shay-in khalaqah",
      "translation": "From what thing [i.e., substance] did He create him?"
    },
    {
      "number": 19,
      "verseKey": "80:19",
      "arabic": "مِن نُّطْفَةٍ خَلَقَهُۥ فَقَدَّرَهُۥ",
      "simpleArabic": "مِن نُّطْفَةٍ خَلَقَهُ فَقَدَّرَهُ",
      "transliteration": "Min nutfatin khalaqahu faqaddarah",
      "translation": "From a sperm-drop He created him and destined for him;[1859]"
    },
    {
      "number": 20,
      "verseKey": "80:20",
      "arabic": "ثُمَّ ٱلسَّبِيلَ يَسَّرَهُۥ",
      "simpleArabic": "ثُمَّ السَّبِيلَ يَسَّرَهُ",
      "transliteration": "Thumma assabeela yassarah",
      "translation": "Then He eased the way for him;[1860]"
    },
    {
      "number": 21,
      "verseKey": "80:21",
      "arabic": "ثُمَّ أَمَاتَهُۥ فَأَقْبَرَهُۥ",
      "simpleArabic": "ثُمَّ أَمَاتَهُ فَأَقْبَرَهُ",
      "transliteration": "Thumma amatahu faaqbarah",
      "translation": "Then He causes his death and provides a grave for him.[1861]"
    },
    {
      "number": 22,
      "verseKey": "80:22",
      "arabic": "ثُمَّ إِذَا شَآءَ أَنشَرَهُۥ",
      "simpleArabic": "ثُمَّ إِذَا شَاءَ أَنشَرَهُ",
      "transliteration": "Thumma itha shaa ansharah",
      "translation": "Then when He wills, He will resurrect him."
    },
    {
      "number": 23,
      "verseKey": "80:23",
      "arabic": "كَلَّا لَمَّا يَقْضِ مَآ أَمَرَهُۥ",
      "simpleArabic": "كَلَّا لَمَّا يَقْضِ مَا أَمَرَهُ",
      "transliteration": "Kalla lamma yaqdi maamarah",
      "translation": "No! He [i.e., man] has not yet accomplished what He commanded him."
    },
    {
      "number": 24,
      "verseKey": "80:24",
      "arabic": "فَلْيَنظُرِ ٱلْإِنسَـٰنُ إِلَىٰ طَعَامِهِۦٓ",
      "simpleArabic": "فَلْيَنظُرِ الْإِنسَانُ إِلَىٰ طَعَامِهِ",
      "transliteration": "Falyanthuri al-insanuila taAAamih",
      "translation": "Then let mankind look at his food -"
    },
    {
      "number": 25,
      "verseKey": "80:25",
      "arabic": "أَنَّا صَبَبْنَا ٱلْمَآءَ صَبًّا",
      "simpleArabic": "أَنَّا صَبَبْنَا الْمَاءَ صَبًّا",
      "transliteration": "Anna sababna almaasabba",
      "translation": "How We poured down water in torrents,"
    },
    {
      "number": 26,
      "verseKey": "80:26",
      "arabic": "ثُمَّ شَقَقْنَا ٱلْأَرْضَ شَقًّا",
      "simpleArabic": "ثُمَّ شَقَقْنَا الْأَرْضَ شَقًّا",
      "transliteration": "Thumma shaqaqna al-arda shaqqa",
      "translation": "Then We broke open the earth, splitting [it with sprouts],"
    },
    {
      "number": 27,
      "verseKey": "80:27",
      "arabic": "فَأَنۢبَتْنَا فِيهَا حَبًّا",
      "simpleArabic": "فَأَنبَتْنَا فِيهَا حَبًّا",
      "transliteration": "Faanbatna feeha habba",
      "translation": "And caused to grow within it grain"
    },
    {
      "number": 28,
      "verseKey": "80:28",
      "arabic": "وَعِنَبًا وَقَضْبًا",
      "simpleArabic": "وَعِنَبًا وَقَضْبًا",
      "transliteration": "WaAAinaban waqadba",
      "translation": "And grapes and herbage"
    },
    {
      "number": 29,
      "verseKey": "80:29",
      "arabic": "وَزَيْتُونًا وَنَخْلًا",
      "simpleArabic": "وَزَيْتُونًا وَنَخْلًا",
      "transliteration": "Wazaytoonan wanakhla",
      "translation": "And olive and palm trees"
    },
    {
      "number": 30,
      "verseKey": "80:30",
      "arabic": "وَحَدَآئِقَ غُلْبًا",
      "simpleArabic": "وَحَدَائِقَ غُلْبًا",
      "transliteration": "Wahada-iqa ghulba",
      "translation": "And gardens of dense shrubbery"
    },
    {
      "number": 31,
      "verseKey": "80:31",
      "arabic": "وَفَـٰكِهَةً وَأَبًّا",
      "simpleArabic": "وَفَاكِهَةً وَأَبًّا",
      "transliteration": "Wafakihatan waabba",
      "translation": "And fruit and grass -"
    },
    {
      "number": 32,
      "verseKey": "80:32",
      "arabic": "مَّتَـٰعًا لَّكُمْ وَلِأَنْعَـٰمِكُمْ",
      "simpleArabic": "مَّتَاعًا لَّكُمْ وَلِأَنْعَامِكُمْ",
      "transliteration": "MataAAan lakum wali-anAAamikum",
      "translation": "[As] enjoyment [i.e., provision] for you and your grazing livestock."
    },
    {
      "number": 33,
      "verseKey": "80:33",
      "arabic": "فَإِذَا جَآءَتِ ٱلصَّآخَّةُ",
      "simpleArabic": "فَإِذَا جَاءَتِ الصَّاخَّةُ",
      "transliteration": "Fa-itha jaati assakhkha",
      "translation": "But when there comes the Deafening Blast[1862]"
    },
    {
      "number": 34,
      "verseKey": "80:34",
      "arabic": "يَوْمَ يَفِرُّ ٱلْمَرْءُ مِنْ أَخِيهِ",
      "simpleArabic": "يَوْمَ يَفِرُّ الْمَرْءُ مِنْ أَخِيهِ",
      "transliteration": "Yawma yafirru almaro min akheeh",
      "translation": "On the Day a man will flee from his brother"
    },
    {
      "number": 35,
      "verseKey": "80:35",
      "arabic": "وَأُمِّهِۦ وَأَبِيهِ",
      "simpleArabic": "وَأُمِّهِ وَأَبِيهِ",
      "transliteration": "Waommihi waabeeh",
      "translation": "And his mother and his father"
    },
    {
      "number": 36,
      "verseKey": "80:36",
      "arabic": "وَصَـٰحِبَتِهِۦ وَبَنِيهِ",
      "simpleArabic": "وَصَاحِبَتِهِ وَبَنِيهِ",
      "transliteration": "Wasahibatihi wabaneeh",
      "translation": "And his wife and his children,"
    },
    {
      "number": 37,
      "verseKey": "80:37",
      "arabic": "لِكُلِّ ٱمْرِئٍ مِّنْهُمْ يَوْمَئِذٍ شَأْنٌ يُغْنِيهِ",
      "simpleArabic": "لِكُلِّ امْرِئٍ مِّنْهُمْ يَوْمَئِذٍ شَأْنٌ يُغْنِيهِ",
      "transliteration": "Likulli imri-in minhum yawma-ithinsha/nun yughneeh",
      "translation": "For every man, that Day, will be a matter adequate for him.[1863]"
    },
    {
      "number": 38,
      "verseKey": "80:38",
      "arabic": "وُجُوهٌ يَوْمَئِذٍ مُّسْفِرَةٌ",
      "simpleArabic": "وُجُوهٌ يَوْمَئِذٍ مُّسْفِرَةٌ",
      "transliteration": "Wujoohun yawma-ithin musfira",
      "translation": "[Some] faces, that Day, will be bright -"
    },
    {
      "number": 39,
      "verseKey": "80:39",
      "arabic": "ضَاحِكَةٌ مُّسْتَبْشِرَةٌ",
      "simpleArabic": "ضَاحِكَةٌ مُّسْتَبْشِرَةٌ",
      "transliteration": "Dahikatun mustabshira",
      "translation": "Laughing, rejoicing at good news."
    },
    {
      "number": 40,
      "verseKey": "80:40",
      "arabic": "وَوُجُوهٌ يَوْمَئِذٍ عَلَيْهَا غَبَرَةٌ",
      "simpleArabic": "وَوُجُوهٌ يَوْمَئِذٍ عَلَيْهَا غَبَرَةٌ",
      "transliteration": "Wawujoohun yawma-ithin AAalayhaghabara",
      "translation": "And [other] faces, that Day, will have upon them dust."
    },
    {
      "number": 41,
      "verseKey": "80:41",
      "arabic": "تَرْهَقُهَا قَتَرَةٌ",
      "simpleArabic": "تَرْهَقُهَا قَتَرَةٌ",
      "transliteration": "Tarhaquha qatara",
      "translation": "Blackness will cover them."
    },
    {
      "number": 42,
      "verseKey": "80:42",
      "arabic": "أُو۟لَـٰٓئِكَ هُمُ ٱلْكَفَرَةُ ٱلْفَجَرَةُ",
      "simpleArabic": "أُولَٰئِكَ هُمُ الْكَفَرَةُ الْفَجَرَةُ",
      "transliteration": "Ola-ika humu alkafaratu alfajara",
      "translation": "Those are the disbelievers, the wicked ones."
    }
  ]
}