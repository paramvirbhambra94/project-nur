{
  "id": 95,
  "name": "At-Tin",
  "transliteratedName": "At-Tīn",
  "arabicName": "التين",
  "translatedName": "The Fig",
  "versesCount": 8,
  "ayahs": [
    {
      "number": 1,
      "verseKey": "95:1",
      "arabic": "وَٱلتِّينِ وَٱلزَّيْتُونِ",
      "transliteration": "Watteeni wazzaytoon",
      "translation": "By the fig and the olive[1947]"
    },
    {
      "number": 2,
      "verseKey": "95:2",
      "arabic": "وَطُورِ سِينِينَ",
      "transliteration": "Watoori seeneen",
      "translation": "And [by] Mount Sinai"
    },
    {
      "number": 3,
      "verseKey": "95:3",
      "arabic": "وَهَـٰذَا ٱلْبَلَدِ ٱلْأَمِينِ",
      "transliteration": "Wahatha albaladi al-ameen",
      "translation": "And [by] this secure city [i.e., Makkah],"
    },
    {
      "number": 4,
      "verseKey": "95:4",
      "arabic": "لَقَدْ خَلَقْنَا ٱلْإِنسَـٰنَ فِىٓ أَحْسَنِ تَقْوِيمٍ",
      "transliteration": "Laqad khalaqna al-insana fee ahsanitaqweem",
      "translation": "We have certainly created man in the best of stature;[1948]"
    },
    {
      "number": 5,
      "verseKey": "95:5",
      "arabic": "ثُمَّ رَدَدْنَـٰهُ أَسْفَلَ سَـٰفِلِينَ",
      "transliteration": "Thumma radadnahu asfala safileen",
      "translation": "Then We return him to the lowest of the low,[1949]"
    },
    {
      "number": 6,
      "verseKey": "95:6",
      "arabic": "إِلَّا ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ فَلَهُمْ أَجْرٌ غَيْرُ مَمْنُونٍ",
      "transliteration": "Illa allatheena amanoowaAAamiloo assalihati falahum ajrun ghayrumamnoon",
      "translation": "Except for those who believe and do righteous deeds, for they will have a reward uninterrupted."
    },
    {
      "number": 7,
      "verseKey": "95:7",
      "arabic": "فَمَا يُكَذِّبُكَ بَعْدُ بِٱلدِّينِ",
      "transliteration": "Fama yukaththibuka baAAdu biddeen",
      "translation": "So what yet causes you to deny the Recompense?[1950]"
    },
    {
      "number": 8,
      "verseKey": "95:8",
      "arabic": "أَلَيْسَ ٱللَّهُ بِأَحْكَمِ ٱلْحَـٰكِمِينَ",
      "transliteration": "Alaysa Allahu bi-ahkami alhakimeen",
      "translation": "Is not Allāh the most just of judges?"
    }
  ]
}