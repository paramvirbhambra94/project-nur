{
  "id": 108,
  "name": "Al-Kawthar",
  "transliteratedName": "Al-Kawthar",
  "arabicName": "الكوثر",
  "translatedName": "The Abundance",
  "versesCount": 3,
  "ayahs": [
    {
      "number": 1,
      "verseKey": "108:1",
      "arabic": " إِنَّآ أَعْطَيْنَـٰكَ ٱلْكَوْثَرَ",
      "simpleArabic": "إِنَّا أَعْطَيْنَاكَ الْكَوْثَرَ",
      "transliteration": "Inna aAAtaynakaalkawthar",
      "translation": "Indeed, We have granted you, [O Muḥammad], al-Kawthar."
    },
    {
      "number": 2,
      "verseKey": "108:2",
      "arabic": "فَصَلِّ لِرَبِّكَ وَٱنْحَرْ",
      "simpleArabic": "فَصَلِّ لِرَبِّكَ وَانْحَرْ",
      "transliteration": "Fasalli lirabbika wanhar",
      "translation": "So pray to your Lord and offer sacrifice [to Him alone]."
    },
    {
      "number": 3,
      "verseKey": "108:3",
      "arabic": "إِنَّ شَانِئَكَ هُوَ ٱلْأَبْتَرُ",
      "simpleArabic": "إِنَّ شَانِئَكَ هُوَ الْأَبْتَرُ",
      "transliteration": "Inna shani-aka huwa al-abtar",
      "translation": "Indeed, your enemy is the one cut off.[2002]"
    }
  ]
}