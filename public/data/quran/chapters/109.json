{
  "id": 109,
  "name": "Al-Kafirun",
  "transliteratedName": "Al-Kāfirūn",
  "arabicName": "الكافرون",
  "translatedName": "The Disbelievers",
  "versesCount": 6,
  "ayahs": [
    {
      "number": 1,
      "verseKey": "109:1",
      "arabic": " قُلْ يَـٰٓأَيُّهَا ٱلْكَـٰفِرُونَ",
      "transliteration": "Qul ya ayyuha alkafiroon",
      "translation": "Say, \"O disbelievers,"
    },
    {
      "number": 2,
      "verseKey": "109:2",
      "arabic": "لَآ أَعْبُدُ مَا تَعْبُدُونَ",
      "transliteration": "La aAAbudu ma taAAbudoon",
      "translation": "I do not worship what you worship."
    },
    {
      "number": 3,
      "verseKey": "109:3",
      "arabic": "وَلَآ أَنتُمْ عَـٰبِدُونَ مَآ أَعْبُدُ",
      "transliteration": "Wala antum AAabidoona maaAAbud",
      "translation": "Nor are you worshippers of what I worship."
    },
    {
      "number": 4,
      "verseKey": "109:4",
      "arabic": "وَلَآ أَنَا۠ عَابِدٌ مَّا عَبَدتُّمْ",
      "transliteration": "Wala ana AAabidun maAAabadtum",
      "translation": "Nor will I be a worshipper of what you worship."
    },
    {
      "number": 5,
      "verseKey": "109:5",
      "arabic": "وَلَآ أَنتُمْ عَـٰبِدُونَ مَآ أَعْبُدُ",
      "transliteration": "Wala antum AAabidoona maaAAbud",
      "translation": "Nor will you be worshippers of what I worship."
    },
    {
      "number": 6,
      "verseKey": "109:6",
      "arabic": "لَكُمْ دِينُكُمْ وَلِىَ دِينِ",
      "transliteration": "Lakum deenukum waliya deen",
      "translation": "For you is your religion, and for me is my religion.\""
    }
  ]
}