{
  "id": 111,
  "name": "Al-Masad",
  "transliteratedName": "Al-Masad",
  "arabicName": "المسد",
  "translatedName": "The Palm Fiber",
  "versesCount": 5,
  "ayahs": [
    {
      "number": 1,
      "verseKey": "111:1",
      "arabic": " تَبَّتْ يَدَآ أَبِى لَهَبٍ وَتَبَّ",
      "transliteration": "Tabbat yada abee lahabin watab",
      "translation": "May the hands of Abū Lahab be ruined, and ruined is he.[2008]"
    },
    {
      "number": 2,
      "verseKey": "111:2",
      "arabic": "مَآ أَغْنَىٰ عَنْهُ مَالُهُۥ وَمَا كَسَبَ",
      "transliteration": "Ma aghna AAanhu maluhuwama kasab",
      "translation": "His wealth will not avail him or that which he gained."
    },
    {
      "number": 3,
      "verseKey": "111:3",
      "arabic": "سَيَصْلَىٰ نَارًا ذَاتَ لَهَبٍ",
      "transliteration": "Sayasla naran thatalahab",
      "translation": "He will [enter to] burn in a Fire of [blazing] flame"
    },
    {
      "number": 4,
      "verseKey": "111:4",
      "arabic": "وَٱمْرَأَتُهُۥ حَمَّالَةَ ٱلْحَطَبِ",
      "transliteration": "Wamraatuhu hammalata alhatab",
      "translation": "And his wife [as well] - the carrier of firewood.[2009]"
    },
    {
      "number": 5,
      "verseKey": "111:5",
      "arabic": "فِى جِيدِهَا حَبْلٌ مِّن مَّسَدٍۭ",
      "transliteration": "Fee jeediha hablun min masad",
      "translation": "Around her neck is a rope of [twisted] fiber."
    }
  ]
}