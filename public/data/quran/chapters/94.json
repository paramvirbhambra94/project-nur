{
  "id": 94,
  "name": "Ash-Sharh",
  "transliteratedName": "Ash-Sharĥ",
  "arabicName": "الشرح",
  "translatedName": "The Relief",
  "versesCount": 8,
  "ayahs": [
    {
      "number": 1,
      "verseKey": "94:1",
      "arabic": " أَلَمْ نَشْرَحْ لَكَ صَدْرَكَ",
      "simpleArabic": "أَلَمْ نَشْرَحْ لَكَ صَدْرَكَ",
      "transliteration": "Alam nashrah laka sadrak",
      "translation": "Did We not expand for you, [O Muḥammad], your breast?[1944]"
    },
    {
      "number": 2,
      "verseKey": "94:2",
      "arabic": "وَوَضَعْنَا عَنكَ وِزْرَكَ",
      "simpleArabic": "وَوَضَعْنَا عَنكَ وِزْرَكَ",
      "transliteration": "WawadaAAna AAanka wizrak",
      "translation": "And We removed from you your burden[1945]"
    },
    {
      "number": 3,
      "verseKey": "94:3",
      "arabic": "ٱلَّذِىٓ أَنقَضَ ظَهْرَكَ",
      "simpleArabic": "الَّذِي أَنقَضَ ظَهْرَكَ",
      "transliteration": "Allathee anqada thahrak",
      "translation": "Which had weighed upon your back"
    },
    {
      "number": 4,
      "verseKey": "94:4",
      "arabic": "وَرَفَعْنَا لَكَ ذِكْرَكَ",
      "simpleArabic": "وَرَفَعْنَا لَكَ ذِكْرَكَ",
      "transliteration": "WarafaAAna laka thikrak",
      "translation": "And raised high for you your repute."
    },
    {
      "number": 5,
      "verseKey": "94:5",
      "arabic": "فَإِنَّ مَعَ ٱلْعُسْرِ يُسْرًا",
      "simpleArabic": "فَإِنَّ مَعَ الْعُسْرِ يُسْرًا",
      "transliteration": "Fa-inna maAAa alAAusri yusra",
      "translation": "For indeed, with hardship [will be] ease [i.e., relief]."
    },
    {
      "number": 6,
      "verseKey": "94:6",
      "arabic": "إِنَّ مَعَ ٱلْعُسْرِ يُسْرًا",
      "simpleArabic": "إِنَّ مَعَ الْعُسْرِ يُسْرًا",
      "transliteration": "Inna maAAa alAAusri yusra",
      "translation": "Indeed, with hardship [will be] ease."
    },
    {
      "number": 7,
      "verseKey": "94:7",
      "arabic": "فَإِذَا فَرَغْتَ فَٱنصَبْ",
      "simpleArabic": "فَإِذَا فَرَغْتَ فَانصَبْ",
      "transliteration": "Fa-itha faraghta fansab",
      "translation": "So when you have finished [your duties], then stand up [for worship]."
    },
    {
      "number": 8,
      "verseKey": "94:8",
      "arabic": "وَإِلَىٰ رَبِّكَ فَٱرْغَب",
      "simpleArabic": "وَإِلَىٰ رَبِّكَ فَارْغَب",
      "transliteration": "Wa-ila rabbika farghab",
      "translation": "And to your Lord direct [your] longing."
    }
  ]
}