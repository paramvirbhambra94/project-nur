{
  "id": 88,
  "name": "Al-Ghashiyah",
  "transliteratedName": "Al-Ghāshiyah",
  "arabicName": "الغاشية",
  "translatedName": "The Overwhelming",
  "versesCount": 26,
  "ayahs": [
    {
      "number": 1,
      "verseKey": "88:1",
      "arabic": " هَلْ أَتَىٰكَ حَدِيثُ ٱلْغَـٰشِيَةِ",
      "transliteration": "Hal ataka hadeethu alghashiyat",
      "translation": "Has there reached you the report of the Overwhelming [event]?"
    },
    {
      "number": 2,
      "verseKey": "88:2",
      "arabic": "وُجُوهٌ يَوْمَئِذٍ خَـٰشِعَةٌ",
      "transliteration": "Wujoohun yawma-ithin khashiAAa",
      "translation": "[Some] faces, that Day, will be humbled,"
    },
    {
      "number": 3,
      "verseKey": "88:3",
      "arabic": "عَامِلَةٌ نَّاصِبَةٌ",
      "transliteration": "AAamilatun nasiba",
      "translation": "Working [hard] and exhausted.[1910]"
    },
    {
      "number": 4,
      "verseKey": "88:4",
      "arabic": "تَصْلَىٰ نَارًا حَامِيَةً",
      "transliteration": "Tasla naran hamiya",
      "translation": "They will [enter to] burn in an intensely hot Fire."
    },
    {
      "number": 5,
      "verseKey": "88:5",
      "arabic": "تُسْقَىٰ مِنْ عَيْنٍ ءَانِيَةٍ",
      "transliteration": "Tusqa min AAaynin aniya",
      "translation": "They will be given drink from a boiling spring."
    },
    {
      "number": 6,
      "verseKey": "88:6",
      "arabic": "لَّيْسَ لَهُمْ طَعَامٌ إِلَّا مِن ضَرِيعٍ",
      "transliteration": "Laysa lahum taAAamun illamin dareeAA",
      "translation": "For them there will be no food except from a poisonous, thorny plant"
    },
    {
      "number": 7,
      "verseKey": "88:7",
      "arabic": "لَّا يُسْمِنُ وَلَا يُغْنِى مِن جُوعٍ",
      "transliteration": "La yusminu wala yughnee minjooAA",
      "translation": "Which neither nourishes nor avails against hunger."
    },
    {
      "number": 8,
      "verseKey": "88:8",
      "arabic": "وُجُوهٌ يَوْمَئِذٍ نَّاعِمَةٌ",
      "transliteration": "Wujoohun yawma-ithin naAAima",
      "translation": "[Other] faces, that Day, will show pleasure."
    },
    {
      "number": 9,
      "verseKey": "88:9",
      "arabic": "لِّسَعْيِهَا رَاضِيَةٌ",
      "transliteration": "LisaAAyiha radiya",
      "translation": "With their effort [they are] satisfied"
    },
    {
      "number": 10,
      "verseKey": "88:10",
      "arabic": "فِى جَنَّةٍ عَالِيَةٍ",
      "transliteration": "Fee jannatin AAaliya",
      "translation": "In an elevated garden,"
    },
    {
      "number": 11,
      "verseKey": "88:11",
      "arabic": "لَّا تَسْمَعُ فِيهَا لَـٰغِيَةً",
      "transliteration": "La tasmaAAu feeha laghiya",
      "translation": "Wherein they will hear no unsuitable speech.[1911]"
    },
    {
      "number": 12,
      "verseKey": "88:12",
      "arabic": "فِيهَا عَيْنٌ جَارِيَةٌ",
      "transliteration": "Feeha AAaynun jariya",
      "translation": "Within it is a flowing spring."
    },
    {
      "number": 13,
      "verseKey": "88:13",
      "arabic": "فِيهَا سُرُرٌ مَّرْفُوعَةٌ",
      "transliteration": "Feeha sururun marfooAAa",
      "translation": "Within it are couches raised high"
    },
    {
      "number": 14,
      "verseKey": "88:14",
      "arabic": "وَأَكْوَابٌ مَّوْضُوعَةٌ",
      "transliteration": "Waakwabun mawdooAAa",
      "translation": "And cups put in place"
    },
    {
      "number": 15,
      "verseKey": "88:15",
      "arabic": "وَنَمَارِقُ مَصْفُوفَةٌ",
      "transliteration": "Wanamariqu masfoofa",
      "translation": "And cushions lined up"
    },
    {
      "number": 16,
      "verseKey": "88:16",
      "arabic": "وَزَرَابِىُّ مَبْثُوثَةٌ",
      "transliteration": "Wazarabiyyu mabthootha",
      "translation": "And carpets spread around."
    },
    {
      "number": 17,
      "verseKey": "88:17",
      "arabic": "أَفَلَا يَنظُرُونَ إِلَى ٱلْإِبِلِ كَيْفَ خُلِقَتْ",
      "transliteration": "Afala yanthuroona ilaal-ibili kayfa khuliqat",
      "translation": "Then do they not look at the camels - how they are created?"
    },
    {
      "number": 18,
      "verseKey": "88:18",
      "arabic": "وَإِلَى ٱلسَّمَآءِ كَيْفَ رُفِعَتْ",
      "transliteration": "Wa-ila assama-i kayfarufiAAat",
      "translation": "And at the sky - how it is raised?"
    },
    {
      "number": 19,
      "verseKey": "88:19",
      "arabic": "وَإِلَى ٱلْجِبَالِ كَيْفَ نُصِبَتْ",
      "transliteration": "Wa-ila aljibali kayfa nusibat",
      "translation": "And at the mountains - how they are erected?"
    },
    {
      "number": 20,
      "verseKey": "88:20",
      "arabic": "وَإِلَى ٱلْأَرْضِ كَيْفَ سُطِحَتْ",
      "transliteration": "Wa-ila al-ardi kayfa sutihat",
      "translation": "And at the earth - how it is spread out?"
    },
    {
      "number": 21,
      "verseKey": "88:21",
      "arabic": "فَذَكِّرْ إِنَّمَآ أَنتَ مُذَكِّرٌ",
      "transliteration": "Fathakkir innama anta muthakkir",
      "translation": "So remind, [O Muḥammad]; you are only a reminder."
    },
    {
      "number": 22,
      "verseKey": "88:22",
      "arabic": "لَّسْتَ عَلَيْهِم بِمُصَيْطِرٍ",
      "transliteration": "Lasta AAalayhim bimusaytir",
      "translation": "You are not over them a controller."
    },
    {
      "number": 23,
      "verseKey": "88:23",
      "arabic": "إِلَّا مَن تَوَلَّىٰ وَكَفَرَ",
      "transliteration": "Illa man tawalla wakafar",
      "translation": "However, he who turns away and disbelieves –"
    },
    {
      "number": 24,
      "verseKey": "88:24",
      "arabic": "فَيُعَذِّبُهُ ٱللَّهُ ٱلْعَذَابَ ٱلْأَكْبَرَ",
      "transliteration": "FayuAAaththibuhu Allahu alAAathabaal-akbar",
      "translation": "Then Allāh will punish him with the greatest punishment."
    },
    {
      "number": 25,
      "verseKey": "88:25",
      "arabic": "إِنَّ إِلَيْنَآ إِيَابَهُمْ",
      "transliteration": "Inna ilayna iyabahum",
      "translation": "Indeed, to Us is their return."
    },
    {
      "number": 26,
      "verseKey": "88:26",
      "arabic": "ثُمَّ إِنَّ عَلَيْنَا حِسَابَهُم",
      "transliteration": "Thumma inna AAalayna hisabahum",
      "translation": "Then indeed, upon Us is their account."
    }
  ]
}