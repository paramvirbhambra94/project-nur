{
  "id": 86,
  "name": "At-Tariq",
  "transliteratedName": "Aţ-Ţāriq",
  "arabicName": "الطارق",
  "translatedName": "The Nightcommer",
  "versesCount": 17,
  "ayahs": [
    {
      "number": 1,
      "verseKey": "86:1",
      "arabic": " وَٱلسَّمَآءِ وَٱلطَّارِقِ",
      "transliteration": "Wassama-i wattariq",
      "translation": "By the sky and the knocker"
    },
    {
      "number": 2,
      "verseKey": "86:2",
      "arabic": "وَمَآ أَدْرَىٰكَ مَا ٱلطَّارِقُ",
      "transliteration": "Wama adraka ma attariq",
      "translation": "And what can make you know what is the knocker?"
    },
    {
      "number": 3,
      "verseKey": "86:3",
      "arabic": "ٱلنَّجْمُ ٱلثَّاقِبُ",
      "transliteration": "Annajmu aththaqib",
      "translation": "It is the piercing star[1901]."
    },
    {
      "number": 4,
      "verseKey": "86:4",
      "arabic": "إِن كُلُّ نَفْسٍ لَّمَّا عَلَيْهَا حَافِظٌ",
      "transliteration": "In kullu nafsin lamma AAalayha hafith",
      "translation": "There is no soul but that it has over it a protector."
    },
    {
      "number": 5,
      "verseKey": "86:5",
      "arabic": "فَلْيَنظُرِ ٱلْإِنسَـٰنُ مِمَّ خُلِقَ",
      "transliteration": "Falyanthuri al-insanumimma khuliq",
      "translation": "So let man observe from what he was created."
    },
    {
      "number": 6,
      "verseKey": "86:6",
      "arabic": "خُلِقَ مِن مَّآءٍ دَافِقٍ",
      "transliteration": "Khuliqa min ma-in dafiq",
      "translation": "He was created from a fluid, ejected,"
    },
    {
      "number": 7,
      "verseKey": "86:7",
      "arabic": "يَخْرُجُ مِنۢ بَيْنِ ٱلصُّلْبِ وَٱلتَّرَآئِبِ",
      "transliteration": "Yakhruju min bayni assulbi wattara-ib",
      "translation": "Emerging from between the backbone and the ribs."
    },
    {
      "number": 8,
      "verseKey": "86:8",
      "arabic": "إِنَّهُۥ عَلَىٰ رَجْعِهِۦ لَقَادِرٌ",
      "transliteration": "Innahu AAala rajAAihi laqadir",
      "translation": "Indeed, He [i.e., Allāh], to return him [to life], is Able."
    },
    {
      "number": 9,
      "verseKey": "86:9",
      "arabic": "يَوْمَ تُبْلَى ٱلسَّرَآئِرُ",
      "transliteration": "Yawma tubla assara-ir",
      "translation": "The Day when secrets will be put on trial,[1902]"
    },
    {
      "number": 10,
      "verseKey": "86:10",
      "arabic": "فَمَا لَهُۥ مِن قُوَّةٍ وَلَا نَاصِرٍ",
      "transliteration": "Fama lahu min quwwatin wala nasir",
      "translation": "Then he [i.e., man] will have no power or any helper."
    },
    {
      "number": 11,
      "verseKey": "86:11",
      "arabic": "وَٱلسَّمَآءِ ذَاتِ ٱلرَّجْعِ",
      "transliteration": "Wassama-i thati arrajAA",
      "translation": "By the sky which sends back[1903]"
    },
    {
      "number": 12,
      "verseKey": "86:12",
      "arabic": "وَٱلْأَرْضِ ذَاتِ ٱلصَّدْعِ",
      "transliteration": "Wal-ardi thati assadAA",
      "translation": "And [by] the earth which splits,[1904]"
    },
    {
      "number": 13,
      "verseKey": "86:13",
      "arabic": "إِنَّهُۥ لَقَوْلٌ فَصْلٌ",
      "transliteration": "Innahu laqawlun fasl",
      "translation": "Indeed, it [i.e., the Qur’ān] is a decisive statement,"
    },
    {
      "number": 14,
      "verseKey": "86:14",
      "arabic": "وَمَا هُوَ بِٱلْهَزْلِ",
      "transliteration": "Wama huwa bilhazl",
      "translation": "And it is not amusement."
    },
    {
      "number": 15,
      "verseKey": "86:15",
      "arabic": "إِنَّهُمْ يَكِيدُونَ كَيْدًا",
      "transliteration": "Innahum yakeedoona kayda",
      "translation": "Indeed, they are planning a plan,"
    },
    {
      "number": 16,
      "verseKey": "86:16",
      "arabic": "وَأَكِيدُ كَيْدًا",
      "transliteration": "Waakeedu kayda",
      "translation": "But I am planning a plan."
    },
    {
      "number": 17,
      "verseKey": "86:17",
      "arabic": "فَمَهِّلِ ٱلْكَـٰفِرِينَ أَمْهِلْهُمْ رُوَيْدًۢا",
      "transliteration": "Famahhili alkafireena amhilhum ruwayda",
      "translation": "So allow time for the disbelievers. Leave them awhile.[1905]"
    }
  ]
}