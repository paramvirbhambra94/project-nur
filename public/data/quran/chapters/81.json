{
  "id": 81,
  "name": "At-Takwir",
  "transliteratedName": "At-Takwīr",
  "arabicName": "التكوير",
  "translatedName": "The Overthrowing",
  "versesCount": 29,
  "ayahs": [
    {
      "number": 1,
      "verseKey": "81:1",
      "arabic": " إِذَا ٱلشَّمْسُ كُوِّرَتْ",
      "simpleArabic": "إِذَا الشَّمْسُ كُوِّرَتْ",
      "transliteration": "Itha ashshamsu kuwwirat",
      "translation": "When the sun is wrapped up [in darkness]"
    },
    {
      "number": 2,
      "verseKey": "81:2",
      "arabic": "وَإِذَا ٱلنُّجُومُ ٱنكَدَرَتْ",
      "simpleArabic": "وَإِذَا النُّجُومُ انكَدَرَتْ",
      "transliteration": "Wa-itha annujoomu inkadarat",
      "translation": "And when the stars fall, dispersing,"
    },
    {
      "number": 3,
      "verseKey": "81:3",
      "arabic": "وَإِذَا ٱلْجِبَالُ سُيِّرَتْ",
      "simpleArabic": "وَإِذَا الْجِبَالُ سُيِّرَتْ",
      "transliteration": "Wa-itha aljibalu suyyirat",
      "translation": "And when the mountains are removed"
    },
    {
      "number": 4,
      "verseKey": "81:4",
      "arabic": "وَإِذَا ٱلْعِشَارُ عُطِّلَتْ",
      "simpleArabic": "وَإِذَا الْعِشَارُ عُطِّلَتْ",
      "transliteration": "Wa-itha alAAisharu AAuttilat",
      "translation": "And when full-term she-camels[1865] are neglected"
    },
    {
      "number": 5,
      "verseKey": "81:5",
      "arabic": "وَإِذَا ٱلْوُحُوشُ حُشِرَتْ",
      "simpleArabic": "وَإِذَا الْوُحُوشُ حُشِرَتْ",
      "transliteration": "Wa-itha alwuhooshu hushirat",
      "translation": "And when the wild beasts are gathered"
    },
    {
      "number": 6,
      "verseKey": "81:6",
      "arabic": "وَإِذَا ٱلْبِحَارُ سُجِّرَتْ",
      "simpleArabic": "وَإِذَا الْبِحَارُ سُجِّرَتْ",
      "transliteration": "Wa-itha albiharu sujjirat",
      "translation": "And when the seas are filled with flame[1866]"
    },
    {
      "number": 7,
      "verseKey": "81:7",
      "arabic": "وَإِذَا ٱلنُّفُوسُ زُوِّجَتْ",
      "simpleArabic": "وَإِذَا النُّفُوسُ زُوِّجَتْ",
      "transliteration": "Wa-itha annufoosu zuwwijat",
      "translation": "And when the souls are paired[1867]"
    },
    {
      "number": 8,
      "verseKey": "81:8",
      "arabic": "وَإِذَا ٱلْمَوْءُۥدَةُ سُئِلَتْ",
      "simpleArabic": "وَإِذَا الْمَوْءُودَةُ سُئِلَتْ",
      "transliteration": "Wa-itha almawoodatu su-ilat",
      "translation": "And when the girl [who was] buried alive is asked"
    },
    {
      "number": 9,
      "verseKey": "81:9",
      "arabic": "بِأَىِّ ذَنۢبٍ قُتِلَتْ",
      "simpleArabic": "بِأَيِّ ذَنبٍ قُتِلَتْ",
      "transliteration": "Bi-ayyi thanbin qutilat",
      "translation": "For what sin she was killed"
    },
    {
      "number": 10,
      "verseKey": "81:10",
      "arabic": "وَإِذَا ٱلصُّحُفُ نُشِرَتْ",
      "simpleArabic": "وَإِذَا الصُّحُفُ نُشِرَتْ",
      "transliteration": "Wa-itha assuhufunushirat",
      "translation": "And when the pages[1868] are spread [i.e., made public]"
    },
    {
      "number": 11,
      "verseKey": "81:11",
      "arabic": "وَإِذَا ٱلسَّمَآءُ كُشِطَتْ",
      "simpleArabic": "وَإِذَا السَّمَاءُ كُشِطَتْ",
      "transliteration": "Wa-itha assamao kushitat",
      "translation": "And when the sky is stripped away"
    },
    {
      "number": 12,
      "verseKey": "81:12",
      "arabic": "وَإِذَا ٱلْجَحِيمُ سُعِّرَتْ",
      "simpleArabic": "وَإِذَا الْجَحِيمُ سُعِّرَتْ",
      "transliteration": "Wa-itha aljaheemu suAAAAirat",
      "translation": "And when Hellfire is set ablaze"
    },
    {
      "number": 13,
      "verseKey": "81:13",
      "arabic": "وَإِذَا ٱلْجَنَّةُ أُزْلِفَتْ",
      "simpleArabic": "وَإِذَا الْجَنَّةُ أُزْلِفَتْ",
      "transliteration": "Wa-itha aljannatu ozlifat",
      "translation": "And when Paradise is brought near,"
    },
    {
      "number": 14,
      "verseKey": "81:14",
      "arabic": "عَلِمَتْ نَفْسٌ مَّآ أَحْضَرَتْ",
      "simpleArabic": "عَلِمَتْ نَفْسٌ مَّا أَحْضَرَتْ",
      "transliteration": "AAalimat nafsun ma ahdarat",
      "translation": "A soul will [then] know what it has brought [with it].[1869]"
    },
    {
      "number": 15,
      "verseKey": "81:15",
      "arabic": "فَلَآ أُقْسِمُ بِٱلْخُنَّسِ",
      "simpleArabic": "فَلَا أُقْسِمُ بِالْخُنَّسِ",
      "transliteration": "Fala oqsimu bilkhunnas",
      "translation": "So I swear by the retreating stars -"
    },
    {
      "number": 16,
      "verseKey": "81:16",
      "arabic": "ٱلْجَوَارِ ٱلْكُنَّسِ",
      "simpleArabic": "الْجَوَارِ الْكُنَّسِ",
      "transliteration": "Aljawari alkunnas",
      "translation": "Those that run [their courses] and disappear [i.e., set]"
    },
    {
      "number": 17,
      "verseKey": "81:17",
      "arabic": "وَٱلَّيْلِ إِذَا عَسْعَسَ",
      "simpleArabic": "وَاللَّيْلِ إِذَا عَسْعَسَ",
      "transliteration": "Wallayli itha AAasAAas",
      "translation": "And by the night as it closes in[1870]"
    },
    {
      "number": 18,
      "verseKey": "81:18",
      "arabic": "وَٱلصُّبْحِ إِذَا تَنَفَّسَ",
      "simpleArabic": "وَالصُّبْحِ إِذَا تَنَفَّسَ",
      "transliteration": "Wassubhi ithatanaffas",
      "translation": "And by the dawn when it breathes [i.e., stirs]"
    },
    {
      "number": 19,
      "verseKey": "81:19",
      "arabic": "إِنَّهُۥ لَقَوْلُ رَسُولٍ كَرِيمٍ",
      "simpleArabic": "إِنَّهُ لَقَوْلُ رَسُولٍ كَرِيمٍ",
      "transliteration": "Innahu laqawlu rasoolin kareem",
      "translation": "[That] indeed, it [i.e., the Qur’ān] is a word [conveyed by] a noble messenger [i.e., Gabriel]"
    },
    {
      "number": 20,
      "verseKey": "81:20",
      "arabic": "ذِى قُوَّةٍ عِندَ ذِى ٱلْعَرْشِ مَكِينٍ",
      "simpleArabic": "ذِي قُوَّةٍ عِندَ ذِي الْعَرْشِ مَكِينٍ",
      "transliteration": "Thee quwwatin AAinda theealAAarshi makeen",
      "translation": "[Who is] possessed of power and with the Owner of the Throne, secure [in position],"
    },
    {
      "number": 21,
      "verseKey": "81:21",
      "arabic": "مُّطَاعٍ ثَمَّ أَمِينٍ",
      "simpleArabic": "مُّطَاعٍ ثَمَّ أَمِينٍ",
      "transliteration": "MutaAAin thamma ameen",
      "translation": "Obeyed there [in the heavens] and trustworthy."
    },
    {
      "number": 22,
      "verseKey": "81:22",
      "arabic": "وَمَا صَاحِبُكُم بِمَجْنُونٍ",
      "simpleArabic": "وَمَا صَاحِبُكُم بِمَجْنُونٍ",
      "transliteration": "Wama sahibukum bimajnoon",
      "translation": "And your companion [i.e., Prophet Muḥammad (ﷺ) ] is not [at all] mad.[1871]"
    },
    {
      "number": 23,
      "verseKey": "81:23",
      "arabic": "وَلَقَدْ رَءَاهُ بِٱلْأُفُقِ ٱلْمُبِينِ",
      "simpleArabic": "وَلَقَدْ رَآهُ بِالْأُفُقِ الْمُبِينِ",
      "transliteration": "Walaqad raahu bilofuqialmubeen",
      "translation": "And he has already seen him [i.e., Gabriel] in the clear horizon.[1872]"
    },
    {
      "number": 24,
      "verseKey": "81:24",
      "arabic": "وَمَا هُوَ عَلَى ٱلْغَيْبِ بِضَنِينٍ",
      "simpleArabic": "وَمَا هُوَ عَلَى الْغَيْبِ بِضَنِينٍ",
      "transliteration": "Wama huwa AAala alghaybi bidaneen",
      "translation": "And he [i.e., Muḥammad (ﷺ)] is not a withholder of [knowledge of] the unseen.[1873]"
    },
    {
      "number": 25,
      "verseKey": "81:25",
      "arabic": "وَمَا هُوَ بِقَوْلِ شَيْطَـٰنٍ رَّجِيمٍ",
      "simpleArabic": "وَمَا هُوَ بِقَوْلِ شَيْطَانٍ رَّجِيمٍ",
      "transliteration": "Wama huwa biqawli shaytaninrajeem",
      "translation": "And it [i.e., the Qur’ān] is not the word of a devil, expelled [from the heavens]."
    },
    {
      "number": 26,
      "verseKey": "81:26",
      "arabic": "فَأَيْنَ تَذْهَبُونَ",
      "simpleArabic": "فَأَيْنَ تَذْهَبُونَ",
      "transliteration": "Faayna tathhaboon",
      "translation": "So where are you going?[1874]"
    },
    {
      "number": 27,
      "verseKey": "81:27",
      "arabic": "إِنْ هُوَ إِلَّا ذِكْرٌ لِّلْعَـٰلَمِينَ",
      "simpleArabic": "إِنْ هُوَ إِلَّا ذِكْرٌ لِّلْعَالَمِينَ",
      "transliteration": "In huwa illa thikrun lilAAalameen",
      "translation": "It is not except a reminder to the worlds"
    },
    {
      "number": 28,
      "verseKey": "81:28",
      "arabic": "لِمَن شَآءَ مِنكُمْ أَن يَسْتَقِيمَ",
      "simpleArabic": "لِمَن شَاءَ مِنكُمْ أَن يَسْتَقِيمَ",
      "transliteration": "Liman shaa minkum an yastaqeem",
      "translation": "For whoever wills among you to take a right course."
    },
    {
      "number": 29,
      "verseKey": "81:29",
      "arabic": "وَمَا تَشَآءُونَ إِلَّآ أَن يَشَآءَ ٱللَّهُ رَبُّ ٱلْعَـٰلَمِينَ",
      "simpleArabic": "وَمَا تَشَاءُونَ إِلَّا أَن يَشَاءَ اللَّهُ رَبُّ الْعَالَمِينَ",
      "transliteration": "Wama tashaoona illa anyashaa Allahu rabbu alAAalameen",
      "translation": "And you do not will except that Allāh wills - Lord of the worlds."
    }
  ]
}