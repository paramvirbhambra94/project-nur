{
  "id": 87,
  "name": "Al-A'la",
  "transliteratedName": "Al-'A`lá",
  "arabicName": "الأعلى",
  "translatedName": "The Most High",
  "versesCount": 19,
  "ayahs": [
    {
      "number": 1,
      "verseKey": "87:1",
      "arabic": " سَبِّحِ ٱسْمَ رَبِّكَ ٱلْأَعْلَى",
      "simpleArabic": "سَبِّحِ اسْمَ رَبِّكَ الْأَعْلَى",
      "transliteration": "Sabbihi isma rabbika al-aAAla",
      "translation": "Exalt the name of your Lord, the Most High,"
    },
    {
      "number": 2,
      "verseKey": "87:2",
      "arabic": "ٱلَّذِى خَلَقَ فَسَوَّىٰ",
      "simpleArabic": "الَّذِي خَلَقَ فَسَوَّىٰ",
      "transliteration": "Allathee khalaqa fasawwa",
      "translation": "Who created and proportioned"
    },
    {
      "number": 3,
      "verseKey": "87:3",
      "arabic": "وَٱلَّذِى قَدَّرَ فَهَدَىٰ",
      "simpleArabic": "وَالَّذِي قَدَّرَ فَهَدَىٰ",
      "transliteration": "Wallathee qaddara fahada",
      "translation": "And who destined and [then] guided"
    },
    {
      "number": 4,
      "verseKey": "87:4",
      "arabic": "وَٱلَّذِىٓ أَخْرَجَ ٱلْمَرْعَىٰ",
      "simpleArabic": "وَالَّذِي أَخْرَجَ الْمَرْعَىٰ",
      "transliteration": "Wallathee akhraja almarAAa",
      "translation": "And who brings out the pasture"
    },
    {
      "number": 5,
      "verseKey": "87:5",
      "arabic": "فَجَعَلَهُۥ غُثَآءً أَحْوَىٰ",
      "simpleArabic": "فَجَعَلَهُ غُثَاءً أَحْوَىٰ",
      "transliteration": "FajaAAalahu ghuthaan ahwa",
      "translation": "And [then] makes it black stubble."
    },
    {
      "number": 6,
      "verseKey": "87:6",
      "arabic": "سَنُقْرِئُكَ فَلَا تَنسَىٰٓ",
      "simpleArabic": "سَنُقْرِئُكَ فَلَا تَنسَىٰ",
      "transliteration": "Sanuqri-oka fala tansa",
      "translation": "We will make you recite, [O Muḥammad], and you will not forget,"
    },
    {
      "number": 7,
      "verseKey": "87:7",
      "arabic": "إِلَّا مَا شَآءَ ٱللَّهُ ۚ إِنَّهُۥ يَعْلَمُ ٱلْجَهْرَ وَمَا يَخْفَىٰ",
      "simpleArabic": "إِلَّا مَا شَاءَ اللَّهُ ۚ إِنَّهُ يَعْلَمُ الْجَهْرَ وَمَا يَخْفَىٰ",
      "transliteration": "Illa ma shaa Allahuinnahu yaAAlamu aljahra wama yakhfa",
      "translation": "Except what Allāh should will. Indeed, He knows what is declared and what is hidden."
    },
    {
      "number": 8,
      "verseKey": "87:8",
      "arabic": "وَنُيَسِّرُكَ لِلْيُسْرَىٰ",
      "simpleArabic": "وَنُيَسِّرُكَ لِلْيُسْرَىٰ",
      "transliteration": "Wanuyassiruka lilyusra",
      "translation": "And We will ease you toward ease.[1907]"
    },
    {
      "number": 9,
      "verseKey": "87:9",
      "arabic": "فَذَكِّرْ إِن نَّفَعَتِ ٱلذِّكْرَىٰ",
      "simpleArabic": "فَذَكِّرْ إِن نَّفَعَتِ الذِّكْرَىٰ",
      "transliteration": "Fathakkir in nafaAAati aththikra",
      "translation": "So remind, if the reminder should benefit;[1908]"
    },
    {
      "number": 10,
      "verseKey": "87:10",
      "arabic": "سَيَذَّكَّرُ مَن يَخْشَىٰ",
      "simpleArabic": "سَيَذَّكَّرُ مَن يَخْشَىٰ",
      "transliteration": "Sayaththakkaru man yakhsha",
      "translation": "He who fears [Allāh] will be reminded."
    },
    {
      "number": 11,
      "verseKey": "87:11",
      "arabic": "وَيَتَجَنَّبُهَا ٱلْأَشْقَى",
      "simpleArabic": "وَيَتَجَنَّبُهَا الْأَشْقَى",
      "transliteration": "Wayatajannabuha al-ashqa",
      "translation": "But the wretched one will avoid it –"
    },
    {
      "number": 12,
      "verseKey": "87:12",
      "arabic": "ٱلَّذِى يَصْلَى ٱلنَّارَ ٱلْكُبْرَىٰ",
      "simpleArabic": "الَّذِي يَصْلَى النَّارَ الْكُبْرَىٰ",
      "transliteration": "Allathee yasla annaraalkubra",
      "translation": "[He] who will [enter and] burn in the greatest Fire,"
    },
    {
      "number": 13,
      "verseKey": "87:13",
      "arabic": "ثُمَّ لَا يَمُوتُ فِيهَا وَلَا يَحْيَىٰ",
      "simpleArabic": "ثُمَّ لَا يَمُوتُ فِيهَا وَلَا يَحْيَىٰ",
      "transliteration": "Thumma la yamootu feeha walayahya",
      "translation": "Neither dying therein nor living."
    },
    {
      "number": 14,
      "verseKey": "87:14",
      "arabic": "قَدْ أَفْلَحَ مَن تَزَكَّىٰ",
      "simpleArabic": "قَدْ أَفْلَحَ مَن تَزَكَّىٰ",
      "transliteration": "Qad aflaha man tazakka",
      "translation": "He has certainly succeeded who purifies himself"
    },
    {
      "number": 15,
      "verseKey": "87:15",
      "arabic": "وَذَكَرَ ٱسْمَ رَبِّهِۦ فَصَلَّىٰ",
      "simpleArabic": "وَذَكَرَ اسْمَ رَبِّهِ فَصَلَّىٰ",
      "transliteration": "Wathakara isma rabbihi fasalla",
      "translation": "And mentions the name of his Lord and prays."
    },
    {
      "number": 16,
      "verseKey": "87:16",
      "arabic": "بَلْ تُؤْثِرُونَ ٱلْحَيَوٰةَ ٱلدُّنْيَا",
      "simpleArabic": "بَلْ تُؤْثِرُونَ الْحَيَاةَ الدُّنْيَا",
      "transliteration": "Bal tu/thiroona alhayata addunya",
      "translation": "But you prefer the worldly life,"
    },
    {
      "number": 17,
      "verseKey": "87:17",
      "arabic": "وَٱلْـَٔاخِرَةُ خَيْرٌ وَأَبْقَىٰٓ",
      "simpleArabic": "وَالْآخِرَةُ خَيْرٌ وَأَبْقَىٰ",
      "transliteration": "Wal-akhiratu khayrun waabqa",
      "translation": "While the Hereafter is better and more enduring."
    },
    {
      "number": 18,
      "verseKey": "87:18",
      "arabic": "إِنَّ هَـٰذَا لَفِى ٱلصُّحُفِ ٱلْأُولَىٰ",
      "simpleArabic": "إِنَّ هَٰذَا لَفِي الصُّحُفِ الْأُولَىٰ",
      "transliteration": "Inna hatha lafee assuhufial-oola",
      "translation": "Indeed, this is in the former scriptures,"
    },
    {
      "number": 19,
      "verseKey": "87:19",
      "arabic": "صُحُفِ إِبْرَٰهِيمَ وَمُوسَىٰ",
      "simpleArabic": "صُحُفِ إِبْرَاهِيمَ وَمُوسَىٰ",
      "transliteration": "Suhufi ibraheema wamoosa",
      "translation": "The scriptures of Abraham and Moses."
    }
  ]
}