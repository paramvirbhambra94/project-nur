{
  "id": 75,
  "name": "Al-Qiyamah",
  "transliteratedName": "Al-Qiyāmah",
  "arabicName": "القيامة",
  "translatedName": "The Resurrection",
  "versesCount": 40,
  "ayahs": [
    {
      "number": 1,
      "verseKey": "75:1",
      "arabic": " لَآ أُقْسِمُ بِيَوْمِ ٱلْقِيَـٰمَةِ",
      "simpleArabic": "لَا أُقْسِمُ بِيَوْمِ الْقِيَامَةِ",
      "transliteration": "La oqsimu biyawmi alqiyamat",
      "translation": "I swear by the Day of Resurrection"
    },
    {
      "number": 2,
      "verseKey": "75:2",
      "arabic": "وَلَآ أُقْسِمُ بِٱلنَّفْسِ ٱللَّوَّامَةِ",
      "simpleArabic": "وَلَا أُقْسِمُ بِالنَّفْسِ اللَّوَّامَةِ",
      "transliteration": "Wala oqsimu binnafsi allawwamat",
      "translation": "And I swear by the reproaching soul[1800] [to the certainty of resurrection]."
    },
    {
      "number": 3,
      "verseKey": "75:3",
      "arabic": "أَيَحْسَبُ ٱلْإِنسَـٰنُ أَلَّن نَّجْمَعَ عِظَامَهُۥ",
      "simpleArabic": "أَيَحْسَبُ الْإِنسَانُ أَلَّن نَّجْمَعَ عِظَامَهُ",
      "transliteration": "Ayahsabu al-insanu allannajmaAAa AAithamah",
      "translation": "Does man think that We will not assemble his bones?"
    },
    {
      "number": 4,
      "verseKey": "75:4",
      "arabic": "بَلَىٰ قَـٰدِرِينَ عَلَىٰٓ أَن نُّسَوِّىَ بَنَانَهُۥ",
      "simpleArabic": "بَلَىٰ قَادِرِينَ عَلَىٰ أَن نُّسَوِّيَ بَنَانَهُ",
      "transliteration": "Bala qadireena AAala annusawwiya bananah",
      "translation": "Yes. [We are] Able [even] to proportion his fingertips."
    },
    {
      "number": 5,
      "verseKey": "75:5",
      "arabic": "بَلْ يُرِيدُ ٱلْإِنسَـٰنُ لِيَفْجُرَ أَمَامَهُۥ",
      "simpleArabic": "بَلْ يُرِيدُ الْإِنسَانُ لِيَفْجُرَ أَمَامَهُ",
      "transliteration": "Bal yureedu al-insanu liyafjura amamah",
      "translation": "But man desires to continue in sin.[1801]"
    },
    {
      "number": 6,
      "verseKey": "75:6",
      "arabic": "يَسْـَٔلُ أَيَّانَ يَوْمُ ٱلْقِيَـٰمَةِ",
      "simpleArabic": "يَسْأَلُ أَيَّانَ يَوْمُ الْقِيَامَةِ",
      "transliteration": "Yas-alu ayyana yawmu alqiyama",
      "translation": "He asks, \"When is the Day of Resurrection?\""
    },
    {
      "number": 7,
      "verseKey": "75:7",
      "arabic": "فَإِذَا بَرِقَ ٱلْبَصَرُ",
      "simpleArabic": "فَإِذَا بَرِقَ الْبَصَرُ",
      "transliteration": "Fa-itha bariqa albasar",
      "translation": "So when vision is dazzled"
    },
    {
      "number": 8,
      "verseKey": "75:8",
      "arabic": "وَخَسَفَ ٱلْقَمَرُ",
      "simpleArabic": "وَخَسَفَ الْقَمَرُ",
      "transliteration": "Wakhasafa alqamar",
      "translation": "And the moon darkens"
    },
    {
      "number": 9,
      "verseKey": "75:9",
      "arabic": "وَجُمِعَ ٱلشَّمْسُ وَٱلْقَمَرُ",
      "simpleArabic": "وَجُمِعَ الشَّمْسُ وَالْقَمَرُ",
      "transliteration": "WajumiAAa ashshamsu walqamar",
      "translation": "And the sun and the moon are joined,"
    },
    {
      "number": 10,
      "verseKey": "75:10",
      "arabic": "يَقُولُ ٱلْإِنسَـٰنُ يَوْمَئِذٍ أَيْنَ ٱلْمَفَرُّ",
      "simpleArabic": "يَقُولُ الْإِنسَانُ يَوْمَئِذٍ أَيْنَ الْمَفَرُّ",
      "transliteration": "Yaqoolu al-insanu yawma-ithinayna almafar",
      "translation": "Man will say on that Day, \"Where is the [place of] escape?\""
    },
    {
      "number": 11,
      "verseKey": "75:11",
      "arabic": "كَلَّا لَا وَزَرَ",
      "simpleArabic": "كَلَّا لَا وَزَرَ",
      "transliteration": "Kalla la wazar",
      "translation": "No! There is no refuge."
    },
    {
      "number": 12,
      "verseKey": "75:12",
      "arabic": "إِلَىٰ رَبِّكَ يَوْمَئِذٍ ٱلْمُسْتَقَرُّ",
      "simpleArabic": "إِلَىٰ رَبِّكَ يَوْمَئِذٍ الْمُسْتَقَرُّ",
      "transliteration": "Ila rabbika yawma-ithinalmustaqar",
      "translation": "To your Lord, that Day, is the [place of] permanence."
    },
    {
      "number": 13,
      "verseKey": "75:13",
      "arabic": "يُنَبَّؤُا۟ ٱلْإِنسَـٰنُ يَوْمَئِذٍۭ بِمَا قَدَّمَ وَأَخَّرَ",
      "simpleArabic": "يُنَبَّأُ الْإِنسَانُ يَوْمَئِذٍ بِمَا قَدَّمَ وَأَخَّرَ",
      "transliteration": "Yunabbao al-insanu yawma-ithinbima qaddama waakhkhar",
      "translation": "Man will be informed that Day of what he sent ahead[1802] and kept back.[1803]"
    },
    {
      "number": 14,
      "verseKey": "75:14",
      "arabic": "بَلِ ٱلْإِنسَـٰنُ عَلَىٰ نَفْسِهِۦ بَصِيرَةٌ",
      "simpleArabic": "بَلِ الْإِنسَانُ عَلَىٰ نَفْسِهِ بَصِيرَةٌ",
      "transliteration": "Bali al-insanu AAala nafsihibaseera",
      "translation": "Rather, man, against himself, will be a witness,[1804]"
    },
    {
      "number": 15,
      "verseKey": "75:15",
      "arabic": "وَلَوْ أَلْقَىٰ مَعَاذِيرَهُۥ",
      "simpleArabic": "وَلَوْ أَلْقَىٰ مَعَاذِيرَهُ",
      "transliteration": "Walaw alqa maAAatheerah",
      "translation": "Even if he presents his excuses."
    },
    {
      "number": 16,
      "verseKey": "75:16",
      "arabic": "لَا تُحَرِّكْ بِهِۦ لِسَانَكَ لِتَعْجَلَ بِهِۦٓ",
      "simpleArabic": "لَا تُحَرِّكْ بِهِ لِسَانَكَ لِتَعْجَلَ بِهِ",
      "transliteration": "La tuharrik bihi lisanakalitaAAjala bih",
      "translation": "Move not your tongue with it, [O Muḥammad], to hasten with it [i.e., recitation of the Qur’ān]."
    },
    {
      "number": 17,
      "verseKey": "75:17",
      "arabic": "إِنَّ عَلَيْنَا جَمْعَهُۥ وَقُرْءَانَهُۥ",
      "simpleArabic": "إِنَّ عَلَيْنَا جَمْعَهُ وَقُرْآنَهُ",
      "transliteration": "Inna AAalayna jamAAahu waqur-anah",
      "translation": "Indeed, upon Us is its collection [in your heart] and [to make possible] its recitation."
    },
    {
      "number": 18,
      "verseKey": "75:18",
      "arabic": "فَإِذَا قَرَأْنَـٰهُ فَٱتَّبِعْ قُرْءَانَهُۥ",
      "simpleArabic": "فَإِذَا قَرَأْنَاهُ فَاتَّبِعْ قُرْآنَهُ",
      "transliteration": "Fa-itha qara/nahu fattabiAAqur-anah",
      "translation": "So when We have recited it [through Gabriel], then follow its recitation."
    },
    {
      "number": 19,
      "verseKey": "75:19",
      "arabic": "ثُمَّ إِنَّ عَلَيْنَا بَيَانَهُۥ",
      "simpleArabic": "ثُمَّ إِنَّ عَلَيْنَا بَيَانَهُ",
      "transliteration": "Thumma inna AAalayna bayanah",
      "translation": "Then upon Us is its clarification [to you]."
    },
    {
      "number": 20,
      "verseKey": "75:20",
      "arabic": "كَلَّا بَلْ تُحِبُّونَ ٱلْعَاجِلَةَ",
      "simpleArabic": "كَلَّا بَلْ تُحِبُّونَ الْعَاجِلَةَ",
      "transliteration": "Kalla bal tuhibboona alAAajila",
      "translation": "No! But you [i.e., mankind] love the immediate"
    },
    {
      "number": 21,
      "verseKey": "75:21",
      "arabic": "وَتَذَرُونَ ٱلْـَٔاخِرَةَ",
      "simpleArabic": "وَتَذَرُونَ الْآخِرَةَ",
      "transliteration": "Watatharoona al-akhira",
      "translation": "And leave [i.e., neglect] the Hereafter."
    },
    {
      "number": 22,
      "verseKey": "75:22",
      "arabic": "وُجُوهٌ يَوْمَئِذٍ نَّاضِرَةٌ",
      "simpleArabic": "وُجُوهٌ يَوْمَئِذٍ نَّاضِرَةٌ",
      "transliteration": "Wujoohun yawma-ithin nadira",
      "translation": "[Some] faces, that Day, will be radiant,"
    },
    {
      "number": 23,
      "verseKey": "75:23",
      "arabic": "إِلَىٰ رَبِّهَا نَاظِرَةٌ",
      "simpleArabic": "إِلَىٰ رَبِّهَا نَاظِرَةٌ",
      "transliteration": "Ila rabbiha nathira",
      "translation": "Looking at their Lord.[1805]"
    },
    {
      "number": 24,
      "verseKey": "75:24",
      "arabic": "وَوُجُوهٌ يَوْمَئِذٍۭ بَاسِرَةٌ",
      "simpleArabic": "وَوُجُوهٌ يَوْمَئِذٍ بَاسِرَةٌ",
      "transliteration": "Wawujoohun yawma-ithin basira",
      "translation": "And [some] faces, that Day, will be contorted,"
    },
    {
      "number": 25,
      "verseKey": "75:25",
      "arabic": "تَظُنُّ أَن يُفْعَلَ بِهَا فَاقِرَةٌ",
      "simpleArabic": "تَظُنُّ أَن يُفْعَلَ بِهَا فَاقِرَةٌ",
      "transliteration": "Tathunnu an yufAAala bihafaqira",
      "translation": "Expecting that there will be done to them [something] backbreaking."
    },
    {
      "number": 26,
      "verseKey": "75:26",
      "arabic": "كَلَّآ إِذَا بَلَغَتِ ٱلتَّرَاقِىَ",
      "simpleArabic": "كَلَّا إِذَا بَلَغَتِ التَّرَاقِيَ",
      "transliteration": "Kalla itha balaghati attaraqiy",
      "translation": "No! When it [i.e., the soul] has reached the collar bones[1806]"
    },
    {
      "number": 27,
      "verseKey": "75:27",
      "arabic": "وَقِيلَ مَنْ ۜ رَاقٍ",
      "simpleArabic": "وَقِيلَ مَنْ ۜ رَاقٍ",
      "transliteration": "Waqeela man raq",
      "translation": "And it is said, \"Who will cure [him]?\""
    },
    {
      "number": 28,
      "verseKey": "75:28",
      "arabic": "وَظَنَّ أَنَّهُ ٱلْفِرَاقُ",
      "simpleArabic": "وَظَنَّ أَنَّهُ الْفِرَاقُ",
      "transliteration": "Wathanna annahu alfiraq",
      "translation": "And he [i.e., the dying one] is certain that it is the [time of] separation"
    },
    {
      "number": 29,
      "verseKey": "75:29",
      "arabic": "وَٱلْتَفَّتِ ٱلسَّاقُ بِٱلسَّاقِ",
      "simpleArabic": "وَالْتَفَّتِ السَّاقُ بِالسَّاقِ",
      "transliteration": "Waltaffati assaqu bilssaq",
      "translation": "And the leg is wound about the leg,[1807]"
    },
    {
      "number": 30,
      "verseKey": "75:30",
      "arabic": "إِلَىٰ رَبِّكَ يَوْمَئِذٍ ٱلْمَسَاقُ",
      "simpleArabic": "إِلَىٰ رَبِّكَ يَوْمَئِذٍ الْمَسَاقُ",
      "transliteration": "Ila rabbika yawma-ithin almasaq",
      "translation": "To your Lord, that Day, will be the procession.[1808]"
    },
    {
      "number": 31,
      "verseKey": "75:31",
      "arabic": "فَلَا صَدَّقَ وَلَا صَلَّىٰ",
      "simpleArabic": "فَلَا صَدَّقَ وَلَا صَلَّىٰ",
      "transliteration": "Fala saddaqa wala salla",
      "translation": "And he [i.e., the disbeliever] had not believed, nor had he prayed."
    },
    {
      "number": 32,
      "verseKey": "75:32",
      "arabic": "وَلَـٰكِن كَذَّبَ وَتَوَلَّىٰ",
      "simpleArabic": "وَلَٰكِن كَذَّبَ وَتَوَلَّىٰ",
      "transliteration": "Walakin kaththaba watawalla",
      "translation": "But [instead], he denied and turned away."
    },
    {
      "number": 33,
      "verseKey": "75:33",
      "arabic": "ثُمَّ ذَهَبَ إِلَىٰٓ أَهْلِهِۦ يَتَمَطَّىٰٓ",
      "simpleArabic": "ثُمَّ ذَهَبَ إِلَىٰ أَهْلِهِ يَتَمَطَّىٰ",
      "transliteration": "Thumma thahaba ila ahlihiyatamatta",
      "translation": "And then he went to his people, swaggering [in pride]."
    },
    {
      "number": 34,
      "verseKey": "75:34",
      "arabic": "أَوْلَىٰ لَكَ فَأَوْلَىٰ",
      "simpleArabic": "أَوْلَىٰ لَكَ فَأَوْلَىٰ",
      "transliteration": "Awla laka faawla",
      "translation": "Woe to you, and woe!"
    },
    {
      "number": 35,
      "verseKey": "75:35",
      "arabic": "ثُمَّ أَوْلَىٰ لَكَ فَأَوْلَىٰٓ",
      "simpleArabic": "ثُمَّ أَوْلَىٰ لَكَ فَأَوْلَىٰ",
      "transliteration": "Thumma awla laka faawla",
      "translation": "Then woe to you, and woe!"
    },
    {
      "number": 36,
      "verseKey": "75:36",
      "arabic": "أَيَحْسَبُ ٱلْإِنسَـٰنُ أَن يُتْرَكَ سُدًى",
      "simpleArabic": "أَيَحْسَبُ الْإِنسَانُ أَن يُتْرَكَ سُدًى",
      "transliteration": "Ayahsabu al-insanu an yutrakasuda",
      "translation": "Does man think that he will be left neglected?[1809]"
    },
    {
      "number": 37,
      "verseKey": "75:37",
      "arabic": "أَلَمْ يَكُ نُطْفَةً مِّن مَّنِىٍّ يُمْنَىٰ",
      "simpleArabic": "أَلَمْ يَكُ نُطْفَةً مِّن مَّنِيٍّ يُمْنَىٰ",
      "transliteration": "Alam yaku nutfatan min manayyin yumna",
      "translation": "Had he not been a sperm from semen emitted?"
    },
    {
      "number": 38,
      "verseKey": "75:38",
      "arabic": "ثُمَّ كَانَ عَلَقَةً فَخَلَقَ فَسَوَّىٰ",
      "simpleArabic": "ثُمَّ كَانَ عَلَقَةً فَخَلَقَ فَسَوَّىٰ",
      "transliteration": "Thumma kana AAalaqatan fakhalaqafasawwa",
      "translation": "Then he was a clinging clot, and [Allāh] created [his form] and proportioned [him]"
    },
    {
      "number": 39,
      "verseKey": "75:39",
      "arabic": "فَجَعَلَ مِنْهُ ٱلزَّوْجَيْنِ ٱلذَّكَرَ وَٱلْأُنثَىٰٓ",
      "simpleArabic": "فَجَعَلَ مِنْهُ الزَّوْجَيْنِ الذَّكَرَ وَالْأُنثَىٰ",
      "transliteration": "FajaAAala minhu azzawjayni aththakarawal-ontha",
      "translation": "And made of him two mates, the male and the female."
    },
    {
      "number": 40,
      "verseKey": "75:40",
      "arabic": "أَلَيْسَ ذَٰلِكَ بِقَـٰدِرٍ عَلَىٰٓ أَن يُحْـِۧىَ ٱلْمَوْتَىٰ",
      "simpleArabic": "أَلَيْسَ ذَٰلِكَ بِقَادِرٍ عَلَىٰ أَن يُحْيِيَ الْمَوْتَىٰ",
      "transliteration": "Alaysa thalika biqadirin AAalaan yuhyiya almawta",
      "translation": "Is not that [Creator] Able to give life to the dead?"
    }
  ]
}