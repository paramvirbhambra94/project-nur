{
  "id": 96,
  "name": "Al-'Alaq",
  "transliteratedName": "Al-`Alaq",
  "arabicName": "العلق",
  "translatedName": "The Clot",
  "versesCount": 19,
  "ayahs": [
    {
      "number": 1,
      "verseKey": "96:1",
      "arabic": " ٱقْرَأْ بِٱسْمِ رَبِّكَ ٱلَّذِى خَلَقَ",
      "simpleArabic": "اقْرَأْ بِاسْمِ رَبِّكَ الَّذِي خَلَقَ",
      "transliteration": "Iqra/ bi-ismi rabbika allathee khalaq",
      "translation": "Recite in the name of your Lord who created –"
    },
    {
      "number": 2,
      "verseKey": "96:2",
      "arabic": "خَلَقَ ٱلْإِنسَـٰنَ مِنْ عَلَقٍ",
      "simpleArabic": "خَلَقَ الْإِنسَانَ مِنْ عَلَقٍ",
      "transliteration": "Khalaqa al-insana min AAalaq",
      "translation": "Created man from a clinging substance."
    },
    {
      "number": 3,
      "verseKey": "96:3",
      "arabic": "ٱقْرَأْ وَرَبُّكَ ٱلْأَكْرَمُ",
      "simpleArabic": "اقْرَأْ وَرَبُّكَ الْأَكْرَمُ",
      "transliteration": "Iqra/ warabbuka al-akram",
      "translation": "Recite, and your Lord is the most Generous -"
    },
    {
      "number": 4,
      "verseKey": "96:4",
      "arabic": "ٱلَّذِى عَلَّمَ بِٱلْقَلَمِ",
      "simpleArabic": "الَّذِي عَلَّمَ بِالْقَلَمِ",
      "transliteration": "Allathee AAallama bilqalam",
      "translation": "Who taught by the pen –"
    },
    {
      "number": 5,
      "verseKey": "96:5",
      "arabic": "عَلَّمَ ٱلْإِنسَـٰنَ مَا لَمْ يَعْلَمْ",
      "simpleArabic": "عَلَّمَ الْإِنسَانَ مَا لَمْ يَعْلَمْ",
      "transliteration": "AAallama al-insana ma lamyaAAlam",
      "translation": "Taught man that which he knew not."
    },
    {
      "number": 6,
      "verseKey": "96:6",
      "arabic": "كَلَّآ إِنَّ ٱلْإِنسَـٰنَ لَيَطْغَىٰٓ",
      "simpleArabic": "كَلَّا إِنَّ الْإِنسَانَ لَيَطْغَىٰ",
      "transliteration": "Kalla inna al-insana layatgha",
      "translation": "No! [But] indeed, man transgresses"
    },
    {
      "number": 7,
      "verseKey": "96:7",
      "arabic": "أَن رَّءَاهُ ٱسْتَغْنَىٰٓ",
      "simpleArabic": "أَن رَّآهُ اسْتَغْنَىٰ",
      "transliteration": "An raahu istaghna",
      "translation": "Because he sees himself self-sufficient."
    },
    {
      "number": 8,
      "verseKey": "96:8",
      "arabic": "إِنَّ إِلَىٰ رَبِّكَ ٱلرُّجْعَىٰٓ",
      "simpleArabic": "إِنَّ إِلَىٰ رَبِّكَ الرُّجْعَىٰ",
      "transliteration": "Inna ila rabbika arrujAAa",
      "translation": "Indeed, to your Lord is the return."
    },
    {
      "number": 9,
      "verseKey": "96:9",
      "arabic": "أَرَءَيْتَ ٱلَّذِى يَنْهَىٰ",
      "simpleArabic": "أَرَأَيْتَ الَّذِي يَنْهَىٰ",
      "transliteration": "Araayta allathee yanha",
      "translation": "Have you seen the one who forbids"
    },
    {
      "number": 10,
      "verseKey": "96:10",
      "arabic": "عَبْدًا إِذَا صَلَّىٰٓ",
      "simpleArabic": "عَبْدًا إِذَا صَلَّىٰ",
      "transliteration": "AAabdan itha salla",
      "translation": "A servant when he prays?"
    },
    {
      "number": 11,
      "verseKey": "96:11",
      "arabic": "أَرَءَيْتَ إِن كَانَ عَلَى ٱلْهُدَىٰٓ",
      "simpleArabic": "أَرَأَيْتَ إِن كَانَ عَلَى الْهُدَىٰ",
      "transliteration": "Araayta in kana AAala alhuda",
      "translation": "Have you seen if he is upon guidance"
    },
    {
      "number": 12,
      "verseKey": "96:12",
      "arabic": "أَوْ أَمَرَ بِٱلتَّقْوَىٰٓ",
      "simpleArabic": "أَوْ أَمَرَ بِالتَّقْوَىٰ",
      "transliteration": "Aw amara bittaqwa",
      "translation": "Or enjoins righteousness?"
    },
    {
      "number": 13,
      "verseKey": "96:13",
      "arabic": "أَرَءَيْتَ إِن كَذَّبَ وَتَوَلَّىٰٓ",
      "simpleArabic": "أَرَأَيْتَ إِن كَذَّبَ وَتَوَلَّىٰ",
      "transliteration": "Araayta in kaththaba watawalla",
      "translation": "Have you seen if he denies and turns away -"
    },
    {
      "number": 14,
      "verseKey": "96:14",
      "arabic": "أَلَمْ يَعْلَم بِأَنَّ ٱللَّهَ يَرَىٰ",
      "simpleArabic": "أَلَمْ يَعْلَم بِأَنَّ اللَّهَ يَرَىٰ",
      "transliteration": "Alam yaAAlam bi-anna Allaha yara",
      "translation": "Does he not know that Allāh sees?"
    },
    {
      "number": 15,
      "verseKey": "96:15",
      "arabic": "كَلَّا لَئِن لَّمْ يَنتَهِ لَنَسْفَعًۢا بِٱلنَّاصِيَةِ",
      "simpleArabic": "كَلَّا لَئِن لَّمْ يَنتَهِ لَنَسْفَعًا بِالنَّاصِيَةِ",
      "transliteration": "Kalla la-in lam yantahi lanasfaAAanbinnasiya",
      "translation": "No! If he does not desist, We will surely drag him by the forelock[1952] –"
    },
    {
      "number": 16,
      "verseKey": "96:16",
      "arabic": "نَاصِيَةٍ كَـٰذِبَةٍ خَاطِئَةٍ",
      "simpleArabic": "نَاصِيَةٍ كَاذِبَةٍ خَاطِئَةٍ",
      "transliteration": "Nasiyatin kathibatin khati-a",
      "translation": "A lying, sinning forelock."
    },
    {
      "number": 17,
      "verseKey": "96:17",
      "arabic": "فَلْيَدْعُ نَادِيَهُۥ",
      "simpleArabic": "فَلْيَدْعُ نَادِيَهُ",
      "transliteration": "FalyadAAu nadiyah",
      "translation": "Then let him call his associates;"
    },
    {
      "number": 18,
      "verseKey": "96:18",
      "arabic": "سَنَدْعُ ٱلزَّبَانِيَةَ",
      "simpleArabic": "سَنَدْعُ الزَّبَانِيَةَ",
      "transliteration": "SanadAAu azzabaniya",
      "translation": "We will call the angels of Hell.[1953]"
    },
    {
      "number": 19,
      "verseKey": "96:19",
      "arabic": "كَلَّا لَا تُطِعْهُ وَٱسْجُدْ وَٱقْتَرِب ۩",
      "simpleArabic": "كَلَّا لَا تُطِعْهُ وَاسْجُدْ وَاقْتَرِب",
      "transliteration": "Kalla la tutiAAhu wasjudwaqtarib",
      "translation": "No! Do not obey him. But prostrate and draw near [to Allāh]."
    }
  ]
}