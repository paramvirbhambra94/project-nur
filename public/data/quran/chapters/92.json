{
  "id": 92,
  "name": "Al-Layl",
  "transliteratedName": "Al-Layl",
  "arabicName": "الليل",
  "translatedName": "The Night",
  "versesCount": 21,
  "ayahs": [
    {
      "number": 1,
      "verseKey": "92:1",
      "arabic": " وَٱلَّيْلِ إِذَا يَغْشَىٰ",
      "simpleArabic": "وَاللَّيْلِ إِذَا يَغْشَىٰ",
      "transliteration": "Wallayli itha yaghsha",
      "translation": "By the night when it covers[1937]"
    },
    {
      "number": 2,
      "verseKey": "92:2",
      "arabic": "وَٱلنَّهَارِ إِذَا تَجَلَّىٰ",
      "simpleArabic": "وَالنَّهَارِ إِذَا تَجَلَّىٰ",
      "transliteration": "Wannahari itha tajalla",
      "translation": "And [by] the day when it appears"
    },
    {
      "number": 3,
      "verseKey": "92:3",
      "arabic": "وَمَا خَلَقَ ٱلذَّكَرَ وَٱلْأُنثَىٰٓ",
      "simpleArabic": "وَمَا خَلَقَ الذَّكَرَ وَالْأُنثَىٰ",
      "transliteration": "Wama khalaqa aththakarawal-ontha",
      "translation": "And [by] He who created the male and female,"
    },
    {
      "number": 4,
      "verseKey": "92:4",
      "arabic": "إِنَّ سَعْيَكُمْ لَشَتَّىٰ",
      "simpleArabic": "إِنَّ سَعْيَكُمْ لَشَتَّىٰ",
      "transliteration": "Inna saAAyakum lashatta",
      "translation": "Indeed, your efforts are diverse."
    },
    {
      "number": 5,
      "verseKey": "92:5",
      "arabic": "فَأَمَّا مَنْ أَعْطَىٰ وَٱتَّقَىٰ",
      "simpleArabic": "فَأَمَّا مَنْ أَعْطَىٰ وَاتَّقَىٰ",
      "transliteration": "Faamma man aAAta wattaqa",
      "translation": "As for he who gives and fears Allāh"
    },
    {
      "number": 6,
      "verseKey": "92:6",
      "arabic": "وَصَدَّقَ بِٱلْحُسْنَىٰ",
      "simpleArabic": "وَصَدَّقَ بِالْحُسْنَىٰ",
      "transliteration": "Wasaddaqa bilhusna",
      "translation": "And believes in the best [reward]."
    },
    {
      "number": 7,
      "verseKey": "92:7",
      "arabic": "فَسَنُيَسِّرُهُۥ لِلْيُسْرَىٰ",
      "simpleArabic": "فَسَنُيَسِّرُهُ لِلْيُسْرَىٰ",
      "transliteration": "Fasanuyassiruhu lilyusra",
      "translation": "We will ease him toward ease."
    },
    {
      "number": 8,
      "verseKey": "92:8",
      "arabic": "وَأَمَّا مَنۢ بَخِلَ وَٱسْتَغْنَىٰ",
      "simpleArabic": "وَأَمَّا مَن بَخِلَ وَاسْتَغْنَىٰ",
      "transliteration": "Waamma man bakhila wastaghna",
      "translation": "But as for he who withholds and considers himself free of need"
    },
    {
      "number": 9,
      "verseKey": "92:9",
      "arabic": "وَكَذَّبَ بِٱلْحُسْنَىٰ",
      "simpleArabic": "وَكَذَّبَ بِالْحُسْنَىٰ",
      "transliteration": "Wakaththaba bilhusna",
      "translation": "And denies the best [reward],"
    },
    {
      "number": 10,
      "verseKey": "92:10",
      "arabic": "فَسَنُيَسِّرُهُۥ لِلْعُسْرَىٰ",
      "simpleArabic": "فَسَنُيَسِّرُهُ لِلْعُسْرَىٰ",
      "transliteration": "Fasanuyassiruhu lilAAusra",
      "translation": "We will ease him toward difficulty."
    },
    {
      "number": 11,
      "verseKey": "92:11",
      "arabic": "وَمَا يُغْنِى عَنْهُ مَالُهُۥٓ إِذَا تَرَدَّىٰٓ",
      "simpleArabic": "وَمَا يُغْنِي عَنْهُ مَالُهُ إِذَا تَرَدَّىٰ",
      "transliteration": "Wama yughnee AAanhu maluhu ithataradda",
      "translation": "And what will his wealth avail him when he falls?[1938]"
    },
    {
      "number": 12,
      "verseKey": "92:12",
      "arabic": "إِنَّ عَلَيْنَا لَلْهُدَىٰ",
      "simpleArabic": "إِنَّ عَلَيْنَا لَلْهُدَىٰ",
      "transliteration": "Inna AAalayna lalhuda",
      "translation": "Indeed, [incumbent] upon Us is guidance."
    },
    {
      "number": 13,
      "verseKey": "92:13",
      "arabic": "وَإِنَّ لَنَا لَلْـَٔاخِرَةَ وَٱلْأُولَىٰ",
      "simpleArabic": "وَإِنَّ لَنَا لَلْآخِرَةَ وَالْأُولَىٰ",
      "transliteration": "Wa-inna lana lal-akhirata wal-oola",
      "translation": "And indeed, to us belongs the Hereafter and the first [life]."
    },
    {
      "number": 14,
      "verseKey": "92:14",
      "arabic": "فَأَنذَرْتُكُمْ نَارًا تَلَظَّىٰ",
      "simpleArabic": "فَأَنذَرْتُكُمْ نَارًا تَلَظَّىٰ",
      "transliteration": "Faanthartukum naran talaththa",
      "translation": "So I have warned you of a Fire which is blazing."
    },
    {
      "number": 15,
      "verseKey": "92:15",
      "arabic": "لَا يَصْلَىٰهَآ إِلَّا ٱلْأَشْقَى",
      "simpleArabic": "لَا يَصْلَاهَا إِلَّا الْأَشْقَى",
      "transliteration": "La yaslaha illaal-ashqa",
      "translation": "None will [enter to] burn therein except the most wretched one"
    },
    {
      "number": 16,
      "verseKey": "92:16",
      "arabic": "ٱلَّذِى كَذَّبَ وَتَوَلَّىٰ",
      "simpleArabic": "الَّذِي كَذَّبَ وَتَوَلَّىٰ",
      "transliteration": "Allathee kaththaba watawalla",
      "translation": "Who had denied and turned away."
    },
    {
      "number": 17,
      "verseKey": "92:17",
      "arabic": "وَسَيُجَنَّبُهَا ٱلْأَتْقَى",
      "simpleArabic": "وَسَيُجَنَّبُهَا الْأَتْقَى",
      "transliteration": "Wasayujannabuha al-atqa",
      "translation": "But the righteous one will avoid it –"
    },
    {
      "number": 18,
      "verseKey": "92:18",
      "arabic": "ٱلَّذِى يُؤْتِى مَالَهُۥ يَتَزَكَّىٰ",
      "simpleArabic": "الَّذِي يُؤْتِي مَالَهُ يَتَزَكَّىٰ",
      "transliteration": "Allathee yu/tee malahuyatazakka",
      "translation": "[He] who gives [from] his wealth to purify himself"
    },
    {
      "number": 19,
      "verseKey": "92:19",
      "arabic": "وَمَا لِأَحَدٍ عِندَهُۥ مِن نِّعْمَةٍ تُجْزَىٰٓ",
      "simpleArabic": "وَمَا لِأَحَدٍ عِندَهُ مِن نِّعْمَةٍ تُجْزَىٰ",
      "transliteration": "Wama li-ahadin AAindahu minniAAmatin tujza",
      "translation": "And not [giving] for anyone who has [done him] a favor to be rewarded[1939] –"
    },
    {
      "number": 20,
      "verseKey": "92:20",
      "arabic": "إِلَّا ٱبْتِغَآءَ وَجْهِ رَبِّهِ ٱلْأَعْلَىٰ",
      "simpleArabic": "إِلَّا ابْتِغَاءَ وَجْهِ رَبِّهِ الْأَعْلَىٰ",
      "transliteration": "Illa ibtighaa wajhi rabbihial-aAAla",
      "translation": "But only seeking the face [i.e., acceptance] of his Lord, Most High."
    },
    {
      "number": 21,
      "verseKey": "92:21",
      "arabic": "وَلَسَوْفَ يَرْضَىٰ",
      "simpleArabic": "وَلَسَوْفَ يَرْضَىٰ",
      "transliteration": "Walasawfa yarda",
      "translation": "And he is going to be satisfied."
    }
  ]
}