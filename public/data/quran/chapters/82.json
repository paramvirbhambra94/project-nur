{
  "id": 82,
  "name": "Al-Infitar",
  "transliteratedName": "Al-'Infiţār",
  "arabicName": "الإنفطار",
  "translatedName": "The Cleaving",
  "versesCount": 19,
  "ayahs": [
    {
      "number": 1,
      "verseKey": "82:1",
      "arabic": " إِذَا ٱلسَّمَآءُ ٱنفَطَرَتْ",
      "transliteration": "Itha assamao infatarat",
      "translation": "When the sky breaks apart"
    },
    {
      "number": 2,
      "verseKey": "82:2",
      "arabic": "وَإِذَا ٱلْكَوَاكِبُ ٱنتَثَرَتْ",
      "transliteration": "Wa-itha alkawakibu intatharat",
      "translation": "And when the stars fall, scattering,"
    },
    {
      "number": 3,
      "verseKey": "82:3",
      "arabic": "وَإِذَا ٱلْبِحَارُ فُجِّرَتْ",
      "transliteration": "Wa-itha albiharu fujjirat",
      "translation": "And when the seas are erupted"
    },
    {
      "number": 4,
      "verseKey": "82:4",
      "arabic": "وَإِذَا ٱلْقُبُورُ بُعْثِرَتْ",
      "transliteration": "Wa-itha alqubooru buAAthirat",
      "translation": "And when the [contents of] graves are scattered [i.e., exposed],"
    },
    {
      "number": 5,
      "verseKey": "82:5",
      "arabic": "عَلِمَتْ نَفْسٌ مَّا قَدَّمَتْ وَأَخَّرَتْ",
      "transliteration": "AAalimat nafsun ma qaddamatwaakhkharat",
      "translation": "A soul will [then] know what it has put forth and kept back."
    },
    {
      "number": 6,
      "verseKey": "82:6",
      "arabic": "يَـٰٓأَيُّهَا ٱلْإِنسَـٰنُ مَا غَرَّكَ بِرَبِّكَ ٱلْكَرِيمِ",
      "transliteration": "Ya ayyuha al-insanu magharraka birabbika alkareem",
      "translation": "O mankind, what has deceived you concerning your Lord, the Generous,"
    },
    {
      "number": 7,
      "verseKey": "82:7",
      "arabic": "ٱلَّذِى خَلَقَكَ فَسَوَّىٰكَ فَعَدَلَكَ",
      "transliteration": "Allathee khalaqaka fasawwakafaAAadalak",
      "translation": "Who created you, proportioned you, and balanced you?"
    },
    {
      "number": 8,
      "verseKey": "82:8",
      "arabic": "فِىٓ أَىِّ صُورَةٍ مَّا شَآءَ رَكَّبَكَ",
      "transliteration": "Fee ayyi sooratin ma shaarakkabak",
      "translation": "In whatever form He willed has He assembled you."
    },
    {
      "number": 9,
      "verseKey": "82:9",
      "arabic": "كَلَّا بَلْ تُكَذِّبُونَ بِٱلدِّينِ",
      "transliteration": "Kalla bal tukaththiboona biddeen",
      "translation": "No! But you deny the Recompense."
    },
    {
      "number": 10,
      "verseKey": "82:10",
      "arabic": "وَإِنَّ عَلَيْكُمْ لَحَـٰفِظِينَ",
      "transliteration": "Wa-inna AAalaykum lahafitheen",
      "translation": "And indeed, [appointed] over you are keepers,[1876]"
    },
    {
      "number": 11,
      "verseKey": "82:11",
      "arabic": "كِرَامًا كَـٰتِبِينَ",
      "transliteration": "Kiraman katibeen",
      "translation": "Noble and recording;"
    },
    {
      "number": 12,
      "verseKey": "82:12",
      "arabic": "يَعْلَمُونَ مَا تَفْعَلُونَ",
      "transliteration": "YaAAlamoona ma tafAAaloon",
      "translation": "They know whatever you do."
    },
    {
      "number": 13,
      "verseKey": "82:13",
      "arabic": "إِنَّ ٱلْأَبْرَارَ لَفِى نَعِيمٍ",
      "transliteration": "Inna al-abrara lafee naAAeem",
      "translation": "Indeed, the righteous will be in pleasure,"
    },
    {
      "number": 14,
      "verseKey": "82:14",
      "arabic": "وَإِنَّ ٱلْفُجَّارَ لَفِى جَحِيمٍ",
      "transliteration": "Wa-inna alfujjara lafee jaheem",
      "translation": "And indeed, the wicked will be in Hellfire."
    },
    {
      "number": 15,
      "verseKey": "82:15",
      "arabic": "يَصْلَوْنَهَا يَوْمَ ٱلدِّينِ",
      "transliteration": "Yaslawnaha yawma addeen",
      "translation": "They will [enter to] burn therein on the Day of Recompense,"
    },
    {
      "number": 16,
      "verseKey": "82:16",
      "arabic": "وَمَا هُمْ عَنْهَا بِغَآئِبِينَ",
      "transliteration": "Wama hum AAanha bigha-ibeen",
      "translation": "And never therefrom will they be absent."
    },
    {
      "number": 17,
      "verseKey": "82:17",
      "arabic": "وَمَآ أَدْرَىٰكَ مَا يَوْمُ ٱلدِّينِ",
      "transliteration": "Wama adraka ma yawmu addeeni",
      "translation": "And what can make you know what is the Day of Recompense?"
    },
    {
      "number": 18,
      "verseKey": "82:18",
      "arabic": "ثُمَّ مَآ أَدْرَىٰكَ مَا يَوْمُ ٱلدِّينِ",
      "transliteration": "Thumma ma adraka mayawmu addeen",
      "translation": "Then, what can make you know what is the Day of Recompense?"
    },
    {
      "number": 19,
      "verseKey": "82:19",
      "arabic": "يَوْمَ لَا تَمْلِكُ نَفْسٌ لِّنَفْسٍ شَيْـًٔا ۖ وَٱلْأَمْرُ يَوْمَئِذٍ لِّلَّهِ",
      "transliteration": "Yawma la tamliku nafsun linafsinshay-an wal-amru yawma-ithin lillah",
      "translation": "It is the Day when a soul will not possess for another soul [power to do] a thing; and the command, that Day, is [entirely] with Allāh."
    }
  ]
}