{
  "id": 93,
  "name": "Ad-Duhaa",
  "transliteratedName": "Ađ-Đuĥaá",
  "arabicName": "الضحى",
  "translatedName": "The Morning Hours",
  "versesCount": 11,
  "ayahs": [
    {
      "number": 1,
      "verseKey": "93:1",
      "arabic": " وَٱلضُّحَىٰ",
      "simpleArabic": "وَالضُّحَىٰ",
      "transliteration": "Wadduha",
      "translation": "By the morning brightness"
    },
    {
      "number": 2,
      "verseKey": "93:2",
      "arabic": "وَٱلَّيْلِ إِذَا سَجَىٰ",
      "simpleArabic": "وَاللَّيْلِ إِذَا سَجَىٰ",
      "transliteration": "Wallayli itha saja",
      "translation": "And [by] the night when it covers with darkness,[1941]"
    },
    {
      "number": 3,
      "verseKey": "93:3",
      "arabic": "مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَىٰ",
      "simpleArabic": "مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَىٰ",
      "transliteration": "Ma waddaAAaka rabbuka wama qala",
      "translation": "Your Lord has not taken leave of you, [O Muḥammad], nor has He detested [you]."
    },
    {
      "number": 4,
      "verseKey": "93:4",
      "arabic": "وَلَلْـَٔاخِرَةُ خَيْرٌ لَّكَ مِنَ ٱلْأُولَىٰ",
      "simpleArabic": "وَلَلْآخِرَةُ خَيْرٌ لَّكَ مِنَ الْأُولَىٰ",
      "transliteration": "Walal-akhiratu khayrun laka minaal-oola",
      "translation": "And the Hereafter is better for you than the first [life]."
    },
    {
      "number": 5,
      "verseKey": "93:5",
      "arabic": "وَلَسَوْفَ يُعْطِيكَ رَبُّكَ فَتَرْضَىٰٓ",
      "simpleArabic": "وَلَسَوْفَ يُعْطِيكَ رَبُّكَ فَتَرْضَىٰ",
      "transliteration": "Walasawfa yuAAteeka rabbuka fatarda",
      "translation": "And your Lord is going to give you, and you will be satisfied."
    },
    {
      "number": 6,
      "verseKey": "93:6",
      "arabic": "أَلَمْ يَجِدْكَ يَتِيمًا فَـَٔاوَىٰ",
      "simpleArabic": "أَلَمْ يَجِدْكَ يَتِيمًا فَآوَىٰ",
      "transliteration": "Alam yajidka yateeman faawa",
      "translation": "Did He not find you an orphan and give [you] refuge?"
    },
    {
      "number": 7,
      "verseKey": "93:7",
      "arabic": "وَوَجَدَكَ ضَآلًّا فَهَدَىٰ",
      "simpleArabic": "وَوَجَدَكَ ضَالًّا فَهَدَىٰ",
      "transliteration": "Wawajadaka dallan fahada",
      "translation": "And He found you lost and guided [you],"
    },
    {
      "number": 8,
      "verseKey": "93:8",
      "arabic": "وَوَجَدَكَ عَآئِلًا فَأَغْنَىٰ",
      "simpleArabic": "وَوَجَدَكَ عَائِلًا فَأَغْنَىٰ",
      "transliteration": "Wawajadaka AAa-ilan faaghna",
      "translation": "And He found you poor and made [you] self-sufficient."
    },
    {
      "number": 9,
      "verseKey": "93:9",
      "arabic": "فَأَمَّا ٱلْيَتِيمَ فَلَا تَقْهَرْ",
      "simpleArabic": "فَأَمَّا الْيَتِيمَ فَلَا تَقْهَرْ",
      "transliteration": "Faamma alyateema fala taqhar",
      "translation": "So as for the orphan, do not oppress [him]."
    },
    {
      "number": 10,
      "verseKey": "93:10",
      "arabic": "وَأَمَّا ٱلسَّآئِلَ فَلَا تَنْهَرْ",
      "simpleArabic": "وَأَمَّا السَّائِلَ فَلَا تَنْهَرْ",
      "transliteration": "Waamma assa-ila falatanhar",
      "translation": "And as for the petitioner,[1942] do not repel [him]."
    },
    {
      "number": 11,
      "verseKey": "93:11",
      "arabic": "وَأَمَّا بِنِعْمَةِ رَبِّكَ فَحَدِّثْ",
      "simpleArabic": "وَأَمَّا بِنِعْمَةِ رَبِّكَ فَحَدِّثْ",
      "transliteration": "Waamma biniAAmati rabbika fahaddith",
      "translation": "But as for the favor of your Lord, report [it]."
    }
  ]
}